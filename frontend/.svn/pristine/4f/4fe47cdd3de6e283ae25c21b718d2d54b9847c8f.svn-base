		<script type="text/ng-template" id="nodes_renderer.html">
			<a href="#/equipments/{{item.idEquipment}}/{{item.Name}}">
				<i ng-class="{
					'fa fa-fw fa-folder-open': item.EquipmentsChilds.length > 0,
					'fa fa-fw fa-file': item.EquipmentsChilds.length == 0}">
				</i> 
				{{item.Name | capitalize}}
				
			</a>					
			<ul ng-model="item.EquipmentsChilds" ng-if="item.EquipmentsChilds.length > 0" >
			  <li ng-repeat="item in item.EquipmentsChilds" ng-include="'nodes_renderer.html'">
			  </li>			  
			</ul>
		</script>

		<script type="text/ng-template" id="nodes_renderer11.html">		
			<a href="#/equipments/{{item.idEquipment}}/{{item.Name | replace}}">
				<i ng-class="{
					'fa fa-fw fa-folder-open': item.CountChilds > 0,
					'fa fa-fw fa-file': !item.CountChilds || item.CountChilds == 0}">
				</i> 
		
					{{item.Name}}
				
				<b class="collapse-sign" ng-click="expandedChilds(this)" ng-if="item.CountChilds > 0"><em ng-class="{'fa fa-collapse-o': !collapsed, 'fa fa-expand-o': collapsed}"></em></b>							
			</a>															
			<ol ui-tree-nodes="" ng-model="item.EquipmentsChilds" ng-class="{hidden: collapsed}" >
			  <li ng-repeat="item in item.EquipmentsChilds"  ui-tree-node ng-include="'nodes_renderer11.html'" ng-show="visibleEquips(item)">
			  </li>			  
			</ol>
		  </script>
		  
		  <script type="text/ng-template" id="terminal_item_renderer.html">
			<div ui-tree-handle class="tree-node tree-node-content">
			  <a href="">
				<span></span>
				<div ng-if="!item.EquipmentsChilds" class="item outcome">				  
				  <span class="" ng-bind-html="item.Name | highlight:queryEquips | trust"> {{item.Name | capitalize}}</span>
				</div>
				
			  </a>
			</div>
		  </script>
		
	</body>

