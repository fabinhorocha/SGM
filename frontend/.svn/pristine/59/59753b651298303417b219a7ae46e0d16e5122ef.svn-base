<script type="text/ng-template" id="componentContent.html">
    <form name="frm" class="smart-form" ng-submit="$ctrl.save()">
            <header>
                <button type="button" class="close" ng-click="$ctrl.cancel()" aria-hidden="true">
                                &times;
                </button>                
                <h4 class="modal-title txt-color-blueDark">
                        <i ng-class = "{
                                'fa-fw fa fa-pencil-square-o': $ctrl.item.action == 'Edit',
                                'fa-fw fa fa-plus-square': $ctrl.item.action == 'Insert'}">
                        </i> 
                        {{$ctrl.item.title}}
                        <span>
                </h4>
            </header>
            
            <fieldset>
                    <section>
                        <label class="label">Equipamento</label>
                        <label class="select">
                            <select id="selectedOilEquipment" name="selectedOilEquipment" class="form-control" required 
                            ng-model="$ctrl.item.equipment"
                            ng-disabled="true" 
                            ng-options="e.Name for e in $ctrl.item.equipmentsAll">
                            </select>                                                                                                                
                            <i></i>
                        </label>   
                    </section>
                    <section>
                        <label class="label">Nome</label>
                                <label class="input">
                                <input name="txtName" maxlength="50" type="text" class="form-control"  required ng-model="$ctrl.item.model.Name" capitalize/>
                        </label>
                    </section>
                    <div class="row">
                        <section class="col col-3">
                            <label class="label">Capacidade (lts)</label>
                            <input type="text" id="txtCapacity" name="txtCapacity" style="width: 100px !important;" required numbersonly ng-model="$ctrl.item.model.Capacity"/>
                        </section>
                        <section class="col col-9">
                            <label class="label">Tipo de Óleo</label>
                            <label class="select">
                                <select id="selectedOilType" 
                                name="selectedOilType"
                                chosen
                                multiple
                                ng-change="$ctrl.addEnabledOilType()"
                                ng-model="$ctrl.EnabledOilTypesIds"
                                ng-options="o.idOilType as o.Name for o in $ctrl.item.model.OilTypes"
                                required>
                                </select>                                                                                                                
                            </label>        
                        </section>
                    </div>
                    <div class="row">
                        <section class="col col-8">
                            <label class="label">Grau ISO dos Contaminantes</label>
                            <textarea id="txtOilGradeISO"  name="txtOilGradeISO" 
                            ng-model="$ctrl.item.model.OilGradeISO" 
                            style="width:100%;height:70px;" ></textarea>
                        </section>
                        <section class="col col-4">
                            <label class="label">Código ISO Limite</label>
                            <input type="text" 
                                name="txtISOLimitCode"
                                ng-model="$ctrl.item.model.ISOLimitCode"
                                style="width:100%;"
                                />
                            <label class="label">Componente Crítico</label>
                            <input type="text" 
                                name="txtCriticalComponent"
                                ng-model="$ctrl.item.model.CriticalComponent"
                                style="width:100%;"
                                />
                        </section>
                    </div>
                    <div class="row">
                        <section class="col col-8">
                            <label class="label">Equipamentos e Máquinas atendidas pela U.H.</label>
                            <textarea id="txtMachinesServed"  name="txtMachinesServed" 
                            ng-model="$ctrl.item.model.MachinesServed" 
                            style="width:100%;height:60px;" ></textarea>
                        </section>
                    </div>
                    <div class="row">
                        <section class="col col-4">
                            <label class="label">Vazão (lts/min)</label>
                            <input type="text" id="txtFlowRate" name="txtFlowRate" numbersonly ng-model="$ctrl.item.model.FlowRate" />
                        </section>
                        <section class="col col-4">
                            <label class="label">Pressão (bar)</label>
                            <input type="text" id="txtPressure" name="txtPressures" numbersonly ng-model="$ctrl.item.model.Preassure"/>
                        </section>
                    </div>
            </fieldset>                                     

            <footer>
                    
                    <button type="submit" class="btn btn-primary">
                                    Salvar
                    </button>

                    <button type="button" class="btn btn-default" ng-click="$ctrl.cancel()" >
                                    Cancelar
                    </button>
            </footer>
    </form>
            
</script>

<script type="text/ng-template" id="oilSupplyContent.html">
    <form name="frm" class="smart-form" ng-submit="$ctrl.save()">
            <header>
                <button type="button" class="close" ng-click="$ctrl.cancel()" aria-hidden="true">
                                &times;
                </button>                
                <h4 class="modal-title txt-color-blueDark">
                        <i ng-class = "{
                                'fa-fw fa fa-pencil-square-o': $ctrl.item.action == 'Edit',
                                'fa-fw fa fa-plus-square': $ctrl.item.action == 'Insert'}">
                        </i> 
                        {{$ctrl.item.title}}
                        <span>
                </h4>
            </header>
            
            <fieldset style="padding: 0px 14px 0px !important;">
                <section style="margin-bottom: 5px !important;">
                    <label class="label">Unidade Hidraúlica</label>
                    <label class="select">
                        <select id="selectedOilComponent" name="selectedOilComponent" class="form-control" required 
                        ng-model="$ctrl.item.component" 
                        ng-options="e.Name for e in $ctrl.item.componentsAll"
                        disabled="true">
                        </select>                                                                                                                
                        <i></i>
                    </label>   
                </section>
                <div class="row">
                        <section class="col col-3" style="margin-bottom: 5px !important;">
                            <label class="label">Quantidade (lts)</label>
                            <input type="text" id="txtQuantity" name="txtQuantity" style="width: 100px !important;" 
                            required 
                            numbersonly 
                            ng-model="$ctrl.item.model.Quantity"
                            ng-readonly="!$ctrl.item.model.EditionEnabled"
                            ng-change="$ctrl.checkChange()"/>
                        </section>
                        <section class="col col-4" style="margin-bottom: 5px !important;">
                            <label class="label">Tipo de Óleo</label>
                            <label class="select">
                                <select id="selectedOilType" name="selectedOilType" class="form-control" required 
                                ng-model="$ctrl.item.model.OilType" 
                                ng-options="o.Name for o in $ctrl.item.model.Component.EnabledOilTypes"
                                ng-disabled="!$ctrl.item.model.EditionEnabled"
                                ng-change="$ctrl.checkChange()">
                                </select>                                                                                                                
                                <i></i>
                            </label>                                                     
                        </section>
                </div>
                <div class="row">
                    <section class="col col-4" style="margin-bottom: 5px !important;">
                            <label class="label">Data Abastecimento</label>
                            <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                <input type="text" id="txtSupplyDateTime" name="txtSupplyDateTime" 
                                ng-model="$ctrl.item.model.SupplyDateTime"  
                                ng-date-picker  data-dateformat="dd/mm/yy"
                                ng-disabled="!$ctrl.item.model.EditionEnabled"
                                ng-change="$ctrl.checkChange()">
                            </label>
                    </section>
                </div>
                <div class="row">
                    <section class="col col-4" style="margin-bottom: 5px !important;">
                            <label class="label">Data Cadastro</label>
                            <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                <input type="text" id="txtInsDateTime" name="txtInsDateTime" 
                                ng-model="$ctrl.item.model.InsDateTime"  
                                ng-date-picker  data-dateformat="dd/mm/yy"
                                ng-disabled="true"/>
                            </label>
                    </section>
                </div>
                <div class="row">
                    <section class="col col-2" style="margin-bottom: 5px !important;">
                        <label class="label">Óleo de Reuso</label>
                    </section>
                    <section class="col col-4" style="margin-bottom: 5px !important;">
                        &nbsp;
                        <label data-ng-repeat="status in $ctrl.FilteredOilStatus">
                            <input
                                name="optionFilteredOil"
                                type="radio"
                                value="{{status}}"
                                ng-model="$ctrl.FilteredOil" 
                                ng-disabled="!$ctrl.item.model.EditionEnabled"
                                ng-change="$ctrl.checkChange()"/>
                                {{status}}
                                &nbsp;&nbsp;
                        </label>                        
                    </section>
                </div>
                <div class="row">
                    <section class="col col-3" style="margin-bottom: 5px !important;">
                            <label class="label">Turno</label>
                            <label class="select">
                                <select id="selectedOilType" name="selectedOilType" class="form-control" required 
                                ng-model="$ctrl.SelectedShift" 
                                ng-options="s.id for s in $ctrl.Shifts"
                                ng-disabled="!$ctrl.item.model.EditionEnabled"
                                ng-change="$ctrl.checkChange()">
                                </select>                                                                                                                
                                <i></i>
                            </label>                                                     
                    </section>
                    <section class="col col-9" style="margin-bottom: 5px !important;">
                            <label class="label">Observação</label>
                            <textarea id="txtComment"  name="txtComment" 
                            ng-model="$ctrl.item.model.Comment" 
                            style="width:100%;height:80px;"
                            ng-change="$ctrl.checkChange()"></textarea> 
                    </section>
                </div>
                <div class="row">
                        <section class="col col-4" style="margin-bottom: 5px !important;">
                            <label class="label">Tipo Abastecimento</label>
                            <label class="select">
                                <select id="selectedOilSupplyType" name="selectedOilSupplyType" class="form-control" required 
                                ng-model="$ctrl.item.model.OilSupplyType" 
                                ng-options="o.Name for o in $ctrl.item.model.OilSupplyTypes" 
                                ng-disabled="!$ctrl.item.model.EditionEnabled"
                                ng-change="$ctrl.checkChange()">
                                </select>                                                                                                                
                                <i></i>
                            </label>
                        </section>
                        <section class="col col-4" style="margin-bottom: 5px !important;" ng-if="$ctrl.item.model.OilSupplyType.Code === 'C'">
                            <label class="label">Gerou Parada</label>
                            <label class="select">
                                <select id="selectedStoppageType" name="selectedStoppageType" class="form-control" 
                                ng-model="$ctrl.item.model.StoppageType" 
                                ng-options="o.Name for o in $ctrl.item.model.StoppageTypes"
                                ng-disabled="!$ctrl.item.model.EditionEnabled"
                                ng-change="$ctrl.checkChange()">
                                </select>                                                                                                                
                                <i></i>
                            </label>
                        </section>
                        <section class="col col-4" style="margin-bottom: 5px !important;" ng-if="$ctrl.item.model.OilSupplyType.Code === 'C' && $ctrl.item.model.StoppageType.Code === 'PNO'">
                            <label class="label">Tempo de Parada (min)</label>
                            <label class="select">
                                <input type="text" id="txtStoppageTime" 
                                name="txtStoppageTime" 
                                ng-change="$ctrl.checkChange()" 
                                ng-readonly="!$ctrl.item.model.EditionEnabled"
                                style="width: 100%;" 
                                numbersonly 
                                ng-model="$ctrl.item.model.StoppageTime"/>
                            </label>
                        </section>
                    </div>            
            </fieldset>
            <footer>
                    <button type="submit" class="btn btn-primary" ng-disabled="$ctrl.saveDisabled">
                                    Salvar
                    </button>

                    <button type="button" class="btn btn-default" ng-click="$ctrl.cancel()" >
                                    Cancelar
                    </button>
            </footer>
    </form>
            
</script>

<div class="row">
    <div class="col-xs-12 col-sm-7 col-md-7 col-lg-12">
        <h1 class="page-title txt-color-blueDark" style="margin: 5px !important;">
            <i class="fa-fw fa fa-table"></i> 
            Administração de Óleo Industrial
            <span>>
            Abastecimento
            </span>                
        </h1>    
    </div>
</div>
<div class="row">
    <section class="col col-lg-3">
        <select id="selectedFactory" name="selectedFactory"
        ng-model="oilFactory" 
        chosen
        options="oilFactories" 
        ng-options="f.Name for f in oilFactories" 
        style="width: 240px !important;"
        ng-change="selectedLevelMenuChange(1)"
        data-placeholder="SELECIONE">
        </select>    
    </section>
    <section class="col col-lg-3">
        <select id="selectedArea" name="selectedArea"
        ng-model="oilArea" 
        chosen
        options="oilAreas" 
        ng-options="a.Name for a in oilAreas" 
        style="width: 240px !important;"
        ng-change="selectedLevelMenuChange(2)"
        data-placeholder="SELECIONE">
        </select>    
    </section>
    <section class="col col-lg-3">
        <select id="selectedEquipment" name="selectedEquipment"
        ng-model="oilEquipment" 
        chosen
        options="oilEquipments" 
        ng-options="e.Name for e in oilEquipments" 
        style="width: 240px !important;"
        ng-change="selectedLevelMenuChange(3)"
        data-placeholder="SELECIONE">
        </select>    
    </section>
    <section class="col col-lg-3">
        <select id="selectedComponent" name="selectedComponent" class="form-control"
        ng-model="oilComponent" 
        chosen
        options="oilComponents" 
        ng-options="c.Name for c in oilComponents" 
        style="width: 240px !important;"
        ng-change="selectedLevelMenuChange(4)"
        data-placeholder="SELECIONE">
        </select>    
    </section>
</div>
<div class="col-lg-12 text-right" style="margin-bottom: 5px; margin-top: 5px;">
    <button class="btn btn-default" style="font: 300 15px/29px 'Open Sans', Helvetica, Arial, sans-serif !important; padding-bottom: 0px !important; padding-top: 0px !important;" 
        ng-click="clearFilters()">
        <i class="fa fa-undo"></i> <span class="hidden-mobile">Limpar Filtros Selecinados</span>
    </button>
    <button class="btn btn-default" style="font: 300 15px/29px 'Open Sans', Helvetica, Arial, sans-serif !important; padding-bottom: 0px !important; padding-top: 0px !important;" 
        ng-disabled="stillHidden" 
        ng-click="newComponent()">
        <i class="fa fa-plus"></i> <span class="hidden-mobile">Nova Unidade Hidráulica</span>
    </button>
</div>
<section id="widget-grid-2" ng-widget-grid class="">            
    <!-- row -->
    <div class="row">
                               
        <!-- NEW WIDGET START -->
        <article class="col-sm-12 col-md-12 col-lg-12">

            <!-- Widget ID (each widget will need unique ID)-->
            <div class="jarviswidget jarviswidget-sortable" data-widget-deletebutton="false" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-collapsed="false" data-widget-togglebutton="false">
                 
                <!-- <header>
                    <span class="widget-icon"> <i class="fa fa-comments"></i> </span> 
                    <h2></h2>  
                </header> -->
                
                <!-- widget div-->
                <div>

                    <!-- widget edit box -->
                    <div class="jarviswidget-editbox">
                        <!-- This area used as dropdown edit box -->

                    </div>
                    <!-- end widget edit box -->

                    <!-- widget content -->
                    <div class="widget-body" ng-hide="!viewLoaded" >
                                                                                               
                        <ul id="oilTabPanel" class="nav nav-tabs bordered">

                            <li ng-repeat="t in tabsRequestView" ng-class="{'active': selTab == t.id}" ng-hide="t.hide">
                                <a href="#t{{t.id}}" target="_self" data-toggle="tab" ng-click= "LoadTabInfo(t.id)" ><i class={{t.class}}></i>{{t.name}}</a>
                            </li>
                            
                        </ul>

                        <div id="requestsTabContent" class="tab-content padding-10">
                             
                            <div ng-class="{'tab-pane fade in active': selTab == 1, 'tab-pane fade': selTab != 1}" id="t1">                                    
                                <div class="row">
                                     <!-- NEW WIDGET START -->
                                     <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
                                         
                                        <!-- Widget ID (each widget will need unique ID)-->
                                        <div class="jarviswidget jarviswidget-color-darken"  data-widget-deletebutton="false" data-widget-togglebutton="false" data-widget-collapsed="false" data-widget-fullscreenbutton="false" data-widget-editbutton="false" data-widget-colorbutton="false">
                                       
                                            <!-- TERJDT -->
                                            <!-- <header>
                                                <span class="widget-icon"> <i class="fa fa-edit"></i> </span>
                                                <h2></h2>				
                                             
                                            </header> -->
    
                                            <!-- widget div-->
                                            <div>
                                            
                                                <!-- widget edit box -->
                                                <div class="jarviswidget-editbox">
                                                    <!-- This area used as dropdown edit box -->
                                                    
                                                </div>
                                                <!-- end widget edit box -->
                                                
                                                <!-- widget content -->
                                                <div class="widget-body no-padding" >
                                                    <div ng-include src="'views/oilManagementConfig.html'"></div>                            
                                                </div>
                                                <!-- end widget content -->
                                            </div>
                                            <!-- end widget div -->
                                        </div>
                                        <!-- end widget -->		
                                    </article>
                                </div>  
                            </div>
                            <div ng-class="{'tab-pane fade in active': selTab == 2, 'tab-pane fade': selTab != 2}" id="t2" >                                    
                                <section ng-widget-grid id="GridHist" class="">
                                    <!-- row -->
                                    <div class="row">
                                
                                        <!-- NEW WIDGET START -->
                                        <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
                                        
                                            <!-- Widget ID (each widget will need unique ID)-->
                                            <!-- <div class="jarviswidget jarviswidget-color-darken"  data-widget-deletebutton="false" data-widget-togglebutton="false" data-widget-collapsed="false" data-widget-fullscreenbutton="false" data-widget-editbutton="false" data-widget-colorbutton="false"> -->
                                                <div class="jarviswidget jarviswidget-color-greenDark"  data-widget-deletebutton="false" data-widget-togglebutton="false" data-widget-collapsed="false" data-widget-fullscreenbutton="false" data-widget-editbutton="false" data-widget-colorbutton="false">
                                            
                                                    <header>
                                                        <span class="widget-icon"> <i class="fa fa-table"></i> </span>
                                                        <h2></h2>
                                    
                                                    </header>
                                    
                                                    <!-- widget div-->
                                                    <div>
                                    
                                                        <!-- widget edit box -->
                                                        <div class="jarviswidget-editbox">
                                                            <!-- This area used as dropdown edit box -->
                                    
                                                        </div>
                                                        <!-- end widget edit box -->
                                    
                                                        <!-- widget content -->
                                                        <div class="widget-body no-padding">
                                                                <!-- <div class="widget-body-toolbar"> -->
                                                                <div class="widget-body-toolbar">
                                                                        <div class="widget-toolbar smart-form">
                                                                                <a class="btn btn-primary" ng-click="LoadTabInfo(selTab)"><i class="fa fa-refresh"></i></a>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form">
                                                                                <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                                                                    <input style="width: 120px" type="text" name="txtDateEnd" ng-model="endDate"  placeholder="Data Final" ng-date-picker  data-dateformat="dd/mm/yy" id="dp112">
                                                                                </label>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form">                                                        
                                                                                <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                                                                    <input style="width: 120px" type="text" name="txtDateStart" ng-model="startDate" placeholder="Data inicial"   ng-date-picker  data-dateformat="dd/mm/yy" id="dp111">                                
                                                                                </label>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form">
                                                                                <span><i class="fa fa-filter"></i> Filtrar:</span>
                                                                        </div>
                                                                        <div excel-export export-data="exportData" style="float: right !important;" file-name="{{fileName}}"></div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important;">
                                                                            <span>
                                                                                <!-- <i class="fa fa-edit"></i>  -->
                                                                                Registros por Página:</span>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important; border-left: none !important; padding-right: 8px !important; padding-left: 0px !important;">
                                                                                <label class="select" style="width:60px">
                                                                                        <select size="1" ng-model="viewbyTab2" ng-change="setItemsPerPageTab2(viewbyTab2)" name="dt_basic_length" aria-controls="dt_basic">
                                                                                            <option value="5">5</option>
                                                                                            <option value="10">10</option>
                                                                                            <option value="25">25</option>
                                                                                            <option value="50">50</option>
                                                                                            <option value="100">100</option>
                                                                                        </select><i></i>
                                                                                </label>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important; border-right: 1px solid rgba(0, 0, 0, 0.09) !important;">
                                                                            <span ng-click="clearAll();"><i class="fa fa-undo"></i>Limpar Filtros</span>
                                                                        </div>                                                                        
                                                                        <!-- <div class="widget-toolbar smart-form" style="float: left !important; border-right: 1px solid rgba(0, 0, 0, 0.09) !important;">
                                                                                <label class="toggle" style="font-size: 13px !important; line-height: 32px !important;">
                                                                                        <input type="checkbox" name="checkbox-toggle" checked="checked" ng-model="onlyActives" ng-disabled="false">
                                                                                        <i data-swchon-text="SIM" data-swchoff-text="NÃO"></i>Só chamados Ativos
                                                                                </label>  
                                                                        </div> -->
                                                                </div>                                                                    
                                                                <div class="dataTables_wrapper form-inline" role="grid">
                                                                    <div style="min-height: 300px !important; height: auto !important; overflow: auto;" class="dt-wrapper" style="overflow: auto;" >
                                                                        <table class="table table-striped table-bordered table-hover" data="{{TryXLfiltrate()}}">
                                                                            <thead>
                                                                                <tr>
                                                                                    <th ng-repeat="col in oilSupplyHistory.cols" ng-show="col.id != 'idOilSupply'" ng-style="{'min-width': col.css.min_width }">
                                                                                        <a>
                                                                                            <span>
                                                                                                {{col.name}}
                                                                                            </span>                                                                                                
                                                                                        </a>
                                                                                        <div ng-if="col.haveFilterFunctionality" class="dropdown" style="float: right">
                                                                                                <button class="dropdown-toggle filterdropdown" ng-class="{active:XLfilters.dict[col.id].isActive}" type="button" data-toggle="dropdown"><span class="glyphicon glyphicon-filter"></span></button>
                                                                                                <div class="dropdown-menu prop" aria-labelledby="btnSearchBatch" style="width: 250px; padding: 15px;">
                                                                                                  <div class="text-right">
                                                                                                    <a href="javascript:void(0);" class="filterlink" ng-click="clearFilter(col.id)">Limpar Filtro</a> | <a "javascript:void(0);" class="filterlink" data-dismiss="modal">Fechar(X)</a>
                                                                                                  </div>
                                                                                                  <form>
                                                                                                    <input type="text" class="form-control input-sm" ng-model="XLfilters.dict[col.id].searchText" placeholder="Filtrar" />
                                                                                                    <div>
                                                                                                      <a href="javascript:void(0);" class="filterlink" ng-click="markAll(col.id,true)">Selecionar Todos</a> | <a "javascript:void(0);" class="filterlink" ng-click="markAll(col.id,false)">Deselecionar Todos</a>
                                                                                                    </div>
                                                                                                    <div class="options">
                                                                                                            <ul style="list-style-type: none; padding: 0">
                                                                                                              <li ng-repeat="item in XLfilters.dict[col.id].options">
                                                                                                                <input id="{{col.id}}Option{{$index}}" type="checkbox" ng-model="XLfilters.dict[col.id].dict[item.title].checked" />&nbsp;<label for="{{col.id}}Option{{$index}}">{{item.title}}</label>
                                                                                                              </li>
                                                                                                            </ul>
                                                                                                          </div>
                                                                                                  </form>
                                                                                                </div>
                                                                                              </div>
                                                                                    </th>                                                                                        
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                    <tr ng-repeat="row in XLfilters.results.slice(((currentPageTab2-1)*itemsPerPageTab2), ((currentPageTab2)*itemsPerPageTab2))">
                                                                                            <td ng-repeat="columnName in row.Columns" ng-show="columnName != 'idOilSupply'">
                                                                                                    {{row[columnName]}}    
                                                                                            </td>
                                                                                    </tr>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                    <div class="dt-row dt-bottom-row">
                                                                        <div class="row">
                                                                            <div class="col-sm-6">
                                                                                <div class="dataTables_info">Mostrando de {{itemPageStartTab2}} até {{itemPageEndTab2}} de {{totalItemsTab2}} registros</div>
                                                                            </div>
                                                                            <div class="col-sm-6 text-right">
                                                                                <div class="dataTables_paginate paging_bootstrap_full">
                                                                                    <ul uib-pagination total-items="totalItemsTab2" ng-model="currentPageTab2" ng-change="pageChanged()" class="pagination-sm" items-per-page="itemsPerPageTab2"></ul>
                                                                                </div> 
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>                                                               
                                                        </div>                                                      
                                                        <!-- end widget content -->
                                                    </div>                                                    
                                                    <!-- end widget div -->
                                            </div>
                                            <!-- end widget -->
                                        </article>
                                        <!-- WIDGET END -->
                                    </div>        
                                </section>                                                             
                            </div>
                            <div ng-class="{'tab-pane fade in active': selTab == 3, 'tab-pane fade': selTab != 3}" id="t3" >
                                <section ng-widget-grid id="GridSettings" class="">
                                    <!-- row -->
                                    <div class="row">
                                
                                        <!-- NEW WIDGET START -->
                                        <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
                                        
                                            <!-- Widget ID (each widget will need unique ID)-->
                                            <!-- <div class="jarviswidget jarviswidget-color-darken"  data-widget-deletebutton="false" data-widget-togglebutton="false" data-widget-collapsed="false" data-widget-fullscreenbutton="false" data-widget-editbutton="false" data-widget-colorbutton="false"> -->
                                                <div class="jarviswidget jarviswidget-color-greenDark"  data-widget-deletebutton="false" data-widget-togglebutton="false" data-widget-collapsed="false" data-widget-fullscreenbutton="false" data-widget-editbutton="false" data-widget-colorbutton="false">
                                            
                                                    <header>
                                                        <span class="widget-icon"> <i class="fa fa-table"></i> </span>
                                                        <h2></h2>
                                    
                                                    </header>
                                    
                                                    <!-- widget div-->
                                                    <div>
                                    
                                                        <!-- widget edit box -->
                                                        <div class="jarviswidget-editbox">
                                                            <!-- This area used as dropdown edit box -->
                                    
                                                        </div>
                                                        <!-- end widget edit box -->
                                    
                                                        <!-- widget content -->
                                                        <div class="widget-body no-padding">
                                                                <!-- <div class="widget-body-toolbar"> -->
                                                                <div class="widget-body-toolbar">
                                                                        <div class="widget-toolbar smart-form">
                                                                                <a class="btn btn-primary" ng-click="LoadTabInfo(selTab)"><i class="fa fa-refresh"></i></a>
                                                                        </div>
                                                                        <!-- <div class="widget-toolbar smart-form">
                                                                                <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                                                                    <input style="width: 120px" type="text" name="txtDateEnd" ng-model="endDate"  placeholder="Data Final" ng-date-picker  data-dateformat="dd/mm/yy" id="dp112">
                                                                                </label>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form">                                                        
                                                                                <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                                                                    <input style="width: 120px" type="text" name="txtDateStart" ng-model="startDate" placeholder="Data inicial"   ng-date-picker  data-dateformat="dd/mm/yy" id="dp111">                                
                                                                                </label>
                                                                        </div> -->
                                                                        <div class="widget-toolbar smart-form">
                                                                                <span><i class="fa fa-filter"></i> Filtrar:</span>
                                                                        </div>
                                                                        <div excel-export export-data="exportData" style="float: right !important;" file-name="{{fileName}}"></div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important;">
                                                                            <span>
                                                                                <!-- <i class="fa fa-edit"></i>  -->
                                                                                Registros por Página:</span>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important; border-left: none !important; padding-right: 8px !important; padding-left: 0px !important;">
                                                                                <label class="select" style="width:60px">
                                                                                        <select size="1" ng-model="viewbyTab3" ng-change="setItemsPerPageTab3(viewbyTab3)" name="dt_basic_length" aria-controls="dt_basic">
                                                                                            <option value="5">5</option>
                                                                                            <option value="10">10</option>
                                                                                            <option value="25">25</option>
                                                                                            <option value="50">50</option>
                                                                                            <option value="100">100</option>
                                                                                        </select><i></i>
                                                                                </label>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important; border-right: 1px solid rgba(0, 0, 0, 0.09) !important;">
                                                                            <span ng-click="clearAll();"><i class="fa fa-undo"></i>Limpar Filtros</span>
                                                                        </div>                                                                        
                                                                        <!-- <div class="widget-toolbar smart-form" style="float: left !important; border-right: 1px solid rgba(0, 0, 0, 0.09) !important;">
                                                                                <label class="toggle" style="font-size: 13px !important; line-height: 32px !important;">
                                                                                        <input type="checkbox" name="checkbox-toggle" checked="checked" ng-model="onlyActives" ng-disabled="false">
                                                                                        <i data-swchon-text="SIM" data-swchoff-text="NÃO"></i>Só chamados Ativos
                                                                                </label>  
                                                                        </div> -->
                                                                </div>                                                                    
                                                                <div class="dataTables_wrapper form-inline" role="grid">
                                                                    <div style="min-height: 300px !important; height: auto !important; overflow: auto;" class="dt-wrapper" style="overflow: auto;" >
                                                                        <table class="table table-striped table-bordered table-hover" data="{{TryXLfiltrate()}}">
                                                                            <thead>
                                                                                <tr>
                                                                                    <th ng-repeat="col in oilComponentSettings.cols" ng-show="col.id != 'idOilSupply'" ng-style="{'min-width': col.css.min_width }">
                                                                                        <a>
                                                                                            <span>
                                                                                                {{col.name}}
                                                                                            </span>                                                                                                
                                                                                        </a>
                                                                                        <div ng-if="col.haveFilterFunctionality" class="dropdown" style="float: right">
                                                                                                <button class="dropdown-toggle filterdropdown" ng-class="{active:XLfilters.dict[col.id].isActive}" type="button" data-toggle="dropdown"><span class="glyphicon glyphicon-filter"></span></button>
                                                                                                <div class="dropdown-menu prop" aria-labelledby="btnSearchBatch" style="width: 250px; padding: 15px;">
                                                                                                  <div class="text-right">
                                                                                                    <a href="javascript:void(0);" class="filterlink" ng-click="clearFilter(col.id)">Limpar Filtro</a> | <a "javascript:void(0);" class="filterlink" data-dismiss="modal">Fechar(X)</a>
                                                                                                  </div>
                                                                                                  <form>
                                                                                                    <input type="text" class="form-control input-sm" ng-model="XLfilters.dict[col.id].searchText" placeholder="Filtrar" />
                                                                                                    <div>
                                                                                                      <a href="javascript:void(0);" class="filterlink" ng-click="markAll(col.id,true)">Selecionar Todos</a> | <a "javascript:void(0);" class="filterlink" ng-click="markAll(col.id,false)">Deselecionar Todos</a>
                                                                                                    </div>
                                                                                                    <div class="options">
                                                                                                            <ul style="list-style-type: none; padding: 0">
                                                                                                              <li ng-repeat="item in XLfilters.dict[col.id].options">
                                                                                                                <input id="{{col.id}}Option{{$index}}" type="checkbox" ng-model="XLfilters.dict[col.id].dict[item.title].checked" />&nbsp;<label for="{{col.id}}Option{{$index}}">{{item.title}}</label>
                                                                                                              </li>
                                                                                                            </ul>
                                                                                                          </div>
                                                                                                  </form>
                                                                                                </div>
                                                                                              </div>
                                                                                    </th>                                                                                        
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                    <tr ng-repeat="row in XLfilters.results.slice(((currentPageTab3-1)*itemsPerPageTab3), ((currentPageTab3)*itemsPerPageTab3))">
                                                                                            <td ng-repeat="columnName in row.Columns" ng-show="columnName != 'idOilSupply'">
                                                                                                    {{row[columnName]}}    
                                                                                            </td>
                                                                                    </tr>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                    <div class="dt-row dt-bottom-row">
                                                                        <div class="row">
                                                                            <div class="col-sm-6">
                                                                                <div class="dataTables_info">Mostrando de {{itemPageStartTab3}} até {{itemPageEndTab3}} de {{totalItemsTab3}} registros</div>
                                                                            </div>
                                                                            <div class="col-sm-6 text-right">
                                                                                <div class="dataTables_paginate paging_bootstrap_full">
                                                                                    <ul uib-pagination total-items="totalItemsTab3" ng-model="currentPageTab3" ng-change="pageChanged()" class="pagination-sm" items-per-page="itemsPerPageTab3"></ul>
                                                                                </div> 
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>                                                               
                                                        </div>                                                      
                                                        <!-- end widget content -->
                                                    </div>                                                    
                                                    <!-- end widget div -->
                                            </div>
                                            <!-- end widget -->
                                        </article>
                                        <!-- WIDGET END -->
                                    </div>        
                                </section>                                                             
                            </div>

                        </div>
                    </div>
                    <!-- end widget content -->
                </div>
                <!-- end widget div -->
            </div>
            <!-- end widget -->                                  
        </article>
        <!-- WIDGET END -->
    </div>
 </section>


