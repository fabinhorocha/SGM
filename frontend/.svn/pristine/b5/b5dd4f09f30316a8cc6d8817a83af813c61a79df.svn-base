<script type="text/ng-template" id="alarmsContent.html">
    <form name="frm" class="smart-form" ng-submit="$ctrl.save()">
            <header>
                <button type="button" class="close" ng-click="$ctrl.cancel()" aria-hidden="true">
                                &times;
                </button>                
                <h4 class="modal-title txt-color-blueDark">
                        <i ng-class = "{
                                'fa-fw fa fa-pencil-square-o': $ctrl.item.action == 'Edit',
                                'fa-fw fa fa-plus-square': $ctrl.item.action == 'Insert'}">
                        </i> 
                        {{$ctrl.item.title}}
                        <span>
                </h4>
            </header>
                
            <fieldset>
                <section>
                    <label class="label">Unidade Hidraúlica</label>
                    <label class="select">
                        <select id="selectedOilComponent" 
                        name="selectedOilComponent" 
                        class="form-control"
                        ng-model="$ctrl.item.component" 
                        ng-options="e.Name for e in $ctrl.item.componentsAll"
                        disabled="true">
                        </select>                                                                                                                
                        <i></i>
                    </label>   
                </section>
                <div class="row">
                    <section class="col col-6" style="padding-right:5px !important; padding-left: 5px !important; margin-top: 5px !important; margin-bottom: 5px !important;">
                        <fieldset style="min-height: 110px !important; margin: 3px !important;border: 1px solid silver !important;padding: 3px !important;border-radius: 4px !important;">
                            <legend style="font-size:14px !important; width: auto !important; padding: 2px !important; border-bottom: none !important;">
                                Alarme de {{$ctrl.item.model.Alarms[0].Alarm.AlarmType.Name}}
                            </legend>
                            <div style="margin-bottom : 10px !important;" data-ng-repeat="setting in $ctrl.item.model.Alarms[0].Alarm.AlarmType.AlarmSettings">
                                <label>{{setting.Name}} ({{setting.Um}})</label>
                                <input type="text" 
                                ng-model="setting.Value" 
                                ng-change="$ctrl.checkChange(0)"/>        
                            </div>
                            <div style="width: 100px !important;">
                                <label class="toggle" style="font-size: 13px !important; line-height: 32px !important;">
                                    <input type="checkbox" 
                                    name="checkbox-toggle" 
                                    checked="checked" 
                                    ng-model="$ctrl.item.model.Alarms[0].Alarm.Active" 
                                    ng-change="$ctrl.checkChange(0)">
                                    <i data-swchon-text="SIM" data-swchoff-text="NÃO"></i>Ativa
                                </label>
                            </div>
                            <div ng-show="$ctrl.item.model.Alarms[0].Alarm.idAlarm  > 0">
                                <i class="fa fa-gear"></i> <a href="" ng-click="$ctrl.editGroupsInAlarm(0)" >Configurar Envio de Email</a>
                            </div>
                        </fieldset>
                    </section>
                    <section class="col col-6" style="padding-right:5px !important; padding-left: 5px !important; margin-top: 5px !important; margin-bottom: 5px !important;">
                        <fieldset style="min-height: 110px !important;margin: 3px !important;border: 1px solid silver !important;padding: 3px !important;border-radius: 4px !important;">
                            <legend style="font-size:14px !important; width: auto !important; padding: 2px !important; border-bottom: none !important;">
                                Alarme de {{$ctrl.item.model.Alarms[1].Alarm.AlarmType.Name}}
                            </legend>
                            <div style="margin-bottom : 10px !important;" data-ng-repeat="setting in $ctrl.item.model.Alarms[1].Alarm.AlarmType.AlarmSettings">
                                <label>{{setting.Name}} ({{setting.Um}})</label>
                                <input type="text" 
                                ng-model="setting.Value" 
                                ng-change="$ctrl.checkChange(1)"/>
                            </div>
                            <div style="width: 100px !important;">
                                <label class="toggle" style="font-size: 13px !important; line-height: 32px !important;">
                                    <input type="checkbox" 
                                    name="checkbox-toggle" 
                                    checked="checked" 
                                    ng-model="$ctrl.item.model.Alarms[1].Alarm.Active" 
                                    ng-change="$ctrl.checkChange(1)">
                                    <i data-swchon-text="SIM" data-swchoff-text="NÃO"></i>Ativa
                                </label>
                            </div>
                            <div ng-show="$ctrl.item.model.Alarms[1].Alarm.idAlarm  > 0">
                                <i class="fa fa-gear"></i> <a href="" ng-click="$ctrl.editGroupsInAlarm(1)" >Configurar Envio de Email</a>
                            </div>
                        </fieldset>
                    </section>
                </div>
                <div class="row">
                    <section class="col col-6" style="padding-right:5px !important; padding-left: 5px !important; margin-top: 5px !important; margin-bottom: 5px !important;">
                        <fieldset style="min-height: 110px !important; margin: 3px !important;border: 1px solid silver !important;padding: 3px !important;border-radius: 4px !important;">
                            <legend style="font-size:14px !important; width: auto !important; padding: 2px !important; border-bottom: none !important;">
                                Alarme de {{$ctrl.item.model.Alarms[2].Alarm.AlarmType.Name}}
                            </legend>
                            <div style="margin-bottom : 10px !important;" data-ng-repeat="setting in $ctrl.item.model.Alarms[2].Alarm.AlarmType.AlarmSettings">
                                <label>{{setting.Name}} ({{setting.Um}})</label>
                                <input type="text" 
                                ng-change="$ctrl.checkChange(2)" 
                                ng-model="setting.Value"/>
                            </div>
                            <div style="width: 100px !important;">
                                <label class="toggle" style="font-size: 13px !important; line-height: 32px !important;">
                                    <input type="checkbox" 
                                    name="checkbox-toggle" 
                                    checked="checked" 
                                    ng-model="$ctrl.item.model.Alarms[2].Alarm.Active" 
                                    ng-change="$ctrl.checkChange(2)">
                                    <i data-swchon-text="SIM" data-swchoff-text="NÃO"></i>Ativa
                                </label>
                            </div>
                            <div ng-show="$ctrl.item.model.Alarms[2].Alarm.idAlarm  > 0">
                                <i class="fa fa-gear"></i> <a href="" ng-click="$ctrl.editGroupsInAlarm(2)" >Configurar Envio de Email</a>
                            </div>
                        </fieldset>
                    </section>
                    <section ng-show="$ctrl.item.model.Alarms.length >= 4" class="col col-6" style="padding-right:5px !important; padding-left: 5px !important; margin-top: 5px !important; margin-bottom: 5px !important;">
                        <fieldset style="min-height: 110px !important; margin: 3px !important;border: 1px solid silver !important;padding: 3px !important;border-radius: 4px !important;">
                            <legend style="font-size:14px !important; width: auto !important; padding: 2px !important; border-bottom: none !important;">
                                Alarme de {{$ctrl.item.model.Alarms[3].Alarm.AlarmType.Name}}
                            </legend>
                            <div style="margin-bottom : 10px !important;" data-ng-repeat="setting in $ctrl.item.model.Alarms[3].Alarm.AlarmType.AlarmSettings">
                                <label>{{setting.Name}} ({{setting.Um}})}</label>
                                <input type="text" 
                                ng-change="$ctrl.checkChange(3)" 
                                ng-model="setting.Value"/>
                            </div>
                            <div style="width: 100px !important;">
                                <label class="toggle" style="font-size: 13px !important; line-height: 32px !important;">
                                    <input type="checkbox" 
                                    name="checkbox-toggle" 
                                    checked="checked" 
                                    ng-model="$ctrl.item.model.Alarms[3].Alarm.Active" 
                                    ng-change="$ctrl.checkChange(3)">
                                    <i data-swchon-text="SIM" data-swchoff-text="NÃO"></i>Ativa
                                </label>
                            </div>
                            <div ng-show="$ctrl.item.model.Alarms[3].Alarm.idAlarm  > 0">
                                <i class="fa fa-gear"></i> <a href="" ng-click="$ctrl.editGroupsInAlarm(3)" >Configurar Envio de Email</a>
                            </div>
                        </fieldset>
                    </section>
                </div>
            </fieldset>
            <footer>
                <button type="submit" class="btn btn-primary" ng-disabled="$ctrl.saveDisabled">
                Salvar
                </button>

                <button type="button" class="btn btn-default" ng-click="$ctrl.cancel()" >
                Cancelar
                </button>
            </footer>
    </form>
</script>

<script type="text/ng-template" id="groupsInAlarmContent.html">
    <form name="frm" class="smart-form" ng-submit="$ctrl2.save()">
            <header>
                <button type="button" class="close" ng-click="$ctrl2.cancel()" aria-hidden="true">
                                &times;
                </button>                
                <h4 class="modal-title txt-color-blueDark">
                        <i ng-class = "{
                                'fa-fw fa fa-pencil-square-o': $ctrl2.item.action == 'Edit',
                                'fa-fw fa fa-plus-square': $ctrl2.item.action == 'Insert'}">
                        </i> 
                        {{$ctrl2.item.title}}
                        <span>
                </h4>
            </header>
            <fieldset style="padding: 5px 14px 5px !important;">
                <section style="width: 80% !important;">
                    <input name="txtName" 
                        type="text" 
                        class="form-control"  
                        required
                        ng-readonly="true"
                        ng-model="$ctrl2.treeDetail"/>
                </section>
                <div class="row">
                    <section class="col col-2">
                        <label class="label">Titulo E-mail</label>
                    </section>
                    <section class="col col-8">
                        <input name="txtSubjectMask" 
                            type="text" 
                            class="form-control"
                            ng-change="$ctrl2.checkChange()"
                            required
                            ng-model="$ctrl2.item.model.Alarm.AlertConfig.SubjectMask"/>
                    </section>
                </div>
                <div class="row">
                    <section class="col col-2">
                        <label class="label">Conteúdo E-mail</label>
                    </section>
                    <section class="col col-8">
                            <textarea id="txtContentMask"  name="txtContentMask" 
                            ng-model="$ctrl2.item.model.Alarm.AlertConfig.ContentMask" 
                            style="width:100%;height:60px;"
                            ng-change="$ctrl2.checkChange()"></textarea>            
                    </section>
                </div>
                <div class="row">
                    <section class="col col-5">
                        <label class="label">Grupos Disponíveis</label>
                        <select multiple ng-model="$ctrl2.GroupsAllSelected" style="min-height: 280px !important; width: 100% !important;">
                            <option ng-selected="g.selected" ng-repeat="g in $ctrl2.item.model.GroupsAll" value="{{g.idAlarmGroup}}">
                                {{g.Name}}
                            </option>
                        </select>
                    </section>
                    <section class="col col-1">
                        <div style="margin-top: 40px !important;">
                            <input type="button" class="btn btn-default" style="width: 50px !important;" ng-click="$ctrl2.transferToRightAllItems()" value=">>" />
                        </div>
                        <div style="margin-top: 5px !important;">
                            <input type="button" class="btn btn-default" style="width: 50px !important;" ng-click="$ctrl2.transferToRightSelectedItems()" value=">" />
                        </div>
                        <div style="margin-top: 5px !important;">
                            <input type="button" class="btn btn-default" style="width: 50px !important;" ng-click="$ctrl2.transferToLeftSelectedItems()" value="<" />
                        </div>
                        <div style="margin-top: 5px !important;">
                            <input type="button" class="btn btn-default" style="width: 50px !important;" ng-click="$ctrl2.transferToLeftAllItems()" value="<<" />
                        </div>
                        <div style="margin-top: 60px !important;">
                                <input type="button" class="btn btn-default" style="width: 50px !important;" ng-click="$ctrl2.transferToRightAllItemsCC()" value=">>" />
                            </div>
                            <div style="margin-top: 5px !important;">
                                <input type="button" class="btn btn-default" style="width: 50px !important;" ng-click="$ctrl2.transferToRightSelectedItemsCC()" value=">" />
                            </div>
                            <div style="margin-top: 5px !important;">
                                <input type="button" class="btn btn-default" style="width: 50px !important;" ng-click="$ctrl2.transferToLeftSelectedItemsCC()" value="<" />
                            </div>
                            <div style="margin-top: 5px !important;">
                                <input type="button" class="btn btn-default" style="width: 50px !important;" ng-click="$ctrl2.transferToLeftAllItemsCC()" value="<<" />
                            </div>
                        </section>
                    <section class="col col-5">
                        <div>
                            <label class="label">Grupos da Alarme (Para)</label>
                            <select multiple ng-model="$ctrl2.GroupsSelected" style="min-height: 125px !important; width: 100% !important;">
                                <option ng-selected="g.selected" ng-repeat="g in $ctrl2.item.model.Alarm.Groups" value="{{g.idAlarmGroup}}">
                                    {{g.Name}}
                                </option>
                            </select>
                        </div>
                        <div>
                            <label class="label">Grupos da Alarme (CC)</label>
                            <select multiple ng-model="$ctrl2.GroupsSelectedCC" style="min-height: 125px !important; width: 100% !important;">
                                <option ng-selected="g.selected" ng-repeat="g in $ctrl2.item.model.Alarm.GroupsCC" value="{{g.idAlarmGroup}}">
                                    {{g.Name}}
                                </option>
                            </select>
                        </div>
                    </section>
                </div>
            </fieldset>
            <footer>
                    <button type="submit" class="btn btn-primary" ng-disabled="$ctrl2.saveDisabled">
                    Salvar
                    </button>

                    <button type="button" class="btn btn-default" ng-click="$ctrl2.cancel()" >
                    Cancelar
                    </button>
            </footer>
    </form>
            
</script>

<div class="row">
    <div class="col-xs-12 col-sm-7 col-md-7 col-lg-12">
        <h1 class="page-title txt-color-blueDark" style="margin: 5px !important;">
            <i class="fa-fw fa fa-table"></i> 
            Administração de Óleo Industrial
            <span>>
            Alarmes
            </span>                
        </h1>    
    </div>
</div>
<div class="row">
    <section class="col col-lg-3">
        <select id="selectedFactory" name="selectedFactory"
        ng-model="oilFactory" 
        chosen
        options="oilFactories" 
        ng-options="f.Name for f in oilFactories" 
        style="width: 240px !important;"
        ng-change="selectedLevelMenuChange(1)"
        data-placeholder="SELECIONE">
        </select>    
    </section>
    <section class="col col-lg-3">
        <select id="selectedArea" name="selectedArea"
        ng-model="oilArea" 
        chosen
        options="oilAreas" 
        ng-options="a.Name for a in oilAreas" 
        style="width: 240px !important;"
        ng-change="selectedLevelMenuChange(2)"
        data-placeholder="SELECIONE">
        </select>    
    </section>
    <section class="col col-lg-3">
        <select id="selectedEquipment" name="selectedEquipment"
        ng-model="oilEquipment" 
        chosen
        options="oilEquipments" 
        ng-options="e.Name for e in oilEquipments" 
        style="width: 240px !important;"
        ng-change="selectedLevelMenuChange(3)"
        data-placeholder="SELECIONE">
        </select>    
    </section>
    <section class="col col-lg-3">
        <select id="selectedComponent" name="selectedComponent" class="form-control"
        ng-model="oilComponent" 
        chosen
        options="oilComponents" 
        ng-options="c.Name for c in oilComponents" 
        style="width: 240px !important;"
        ng-change="selectedLevelMenuChange(4)"
        data-placeholder="SELECIONE">
        </select>    
    </section>
</div>
<div class="col-lg-12 text-right" style="margin-bottom: 5px; margin-top: 5px;">
    <button class="btn btn-default" style="font: 300 15px/29px 'Open Sans', Helvetica, Arial, sans-serif !important; padding-bottom: 0px !important; padding-top: 0px !important;" 
        ng-click="clearFilters()">
        <i class="fa fa-undo"></i> <span class="hidden-mobile">Limpar Filtros Selecinados</span>
    </button>
    <button class="btn btn-default" style="font: 300 15px/29px 'Open Sans', Helvetica, Arial, sans-serif !important; padding-bottom: 0px !important; padding-top: 0px !important;" 
        ng-disabled="stillHiddenAlarmEdit" 
        ng-click="newAlarm()">
        <i class="fa fa-edit"></i> <span class="hidden-mobile">Editar Alarmes</span>
    </button>
</div>
<section id="widget-grid-2" ng-widget-grid class="">            
    <!-- row -->
    <div class="row">
                               
        <!-- NEW WIDGET START -->
        <article class="col-sm-12 col-md-12 col-lg-12">

            <!-- Widget ID (each widget will need unique ID)-->
            <div class="jarviswidget jarviswidget-sortable" data-widget-deletebutton="false" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-collapsed="false" data-widget-togglebutton="false">
                 
                <!-- widget div-->
                <div>

                    <!-- widget edit box -->
                    <div class="jarviswidget-editbox">
                        <!-- This area used as dropdown edit box -->

                    </div>
                    <!-- end widget edit box -->

                    <!-- widget content -->
                    <div class="widget-body" ng-hide="!viewLoaded" >
                                                                                               
                        <ul id="oilTabPanel" class="nav nav-tabs bordered">

                            <li ng-repeat="t in tabsRequestView" ng-class="{'active': selTab == t.id}" ng-hide="t.hide">
                                <a href="#t{{t.id}}" target="_self" data-toggle="tab" ng-click= "LoadTabInfo(t.id)" ><i class={{t.class}}></i>{{t.name}}</a>
                            </li>
                            
                        </ul>

                        <div id="requestsTabContent" class="tab-content padding-10">
                            <!-- Alarm Tab -->
                            <div ng-class="{'tab-pane fade in active': selTab == 1, 'tab-pane fade': selTab != 1}" id="t1" >                                    
                                <section ng-widget-grid id="GridAlarm" class="">
                                    <!-- row -->
                                    <div class="row">
                                
                                        <!-- NEW WIDGET START -->
                                        <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
                                        
                                            <!-- Widget ID (each widget will need unique ID)-->
                                            <!-- <div class="jarviswidget jarviswidget-color-darken"  data-widget-deletebutton="false" data-widget-togglebutton="false" data-widget-collapsed="false" data-widget-fullscreenbutton="false" data-widget-editbutton="false" data-widget-colorbutton="false"> -->
                                                <div class="jarviswidget jarviswidget-color-greenDark"  data-widget-deletebutton="false" data-widget-togglebutton="false" data-widget-collapsed="false" data-widget-fullscreenbutton="false" data-widget-editbutton="false" data-widget-colorbutton="false">
                                            
                                                    <header>
                                                        <span class="widget-icon"> <i class="fa fa-table"></i> </span>
                                                        <h2></h2>
                                    
                                                    </header>
                                    
                                                    <!-- widget div-->
                                                    <div>
                                    
                                                        <!-- widget edit box -->
                                                        <div class="jarviswidget-editbox">
                                                            <!-- This area used as dropdown edit box -->
                                    
                                                        </div>
                                                        <!-- end widget edit box -->
                                    
                                                        <!-- widget content -->
                                                        <div class="widget-body no-padding">
                                                                <!-- <div class="widget-body-toolbar"> -->
                                                                <div class="widget-body-toolbar">
                                                                        <div class="widget-toolbar smart-form">
                                                                                <a class="btn btn-primary" ng-click="LoadTabInfo(selTab)"><i class="fa fa-refresh"></i></a>
                                                                        </div>
                                                                        <!-- <div class="widget-toolbar smart-form">
                                                                                <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                                                                    <input style="width: 120px" type="text" name="txtDateEnd" ng-model="endDate"  placeholder="Data Final" ng-date-picker  data-dateformat="dd/mm/yy" id="dp112">
                                                                                </label>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form">                                                        
                                                                                <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                                                                    <input style="width: 120px" type="text" name="txtDateStart" ng-model="startDate" placeholder="Data inicial"   ng-date-picker  data-dateformat="dd/mm/yy" id="dp111">                                
                                                                                </label>
                                                                        </div> -->
                                                                        <!-- <div class="widget-toolbar smart-form">
                                                                                <span><i class="fa fa-filter"></i> Filtrar:</span>
                                                                        </div> -->
                                                                        <div excel-export export-data="exportData" style="float: right !important;" file-name="{{fileName}}"></div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important;">
                                                                            <span>
                                                                                <!-- <i class="fa fa-edit"></i>  -->
                                                                                Registros por Página:</span>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important; border-left: none !important; padding-right: 8px !important; padding-left: 0px !important;">
                                                                                <label class="select" style="width:60px">
                                                                                        <select size="1" ng-model="viewbyTab" ng-change="setItemsPerPageTab(viewbyTab)" name="dt_basic_length" aria-controls="dt_basic">
                                                                                            <option value="5">5</option>
                                                                                            <option value="10">10</option>
                                                                                            <option value="25">25</option>
                                                                                            <option value="50">50</option>
                                                                                            <option value="100">100</option>
                                                                                        </select><i></i>
                                                                                </label>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important; border-right: 1px solid rgba(0, 0, 0, 0.09) !important;">
                                                                            <span ng-click="clearAll();"><i class="fa fa-undo"></i>Limpar Filtros</span>
                                                                        </div>                                                                        
                                                                </div>                                                                    
                                                                <div class="dataTables_wrapper form-inline" role="grid">
                                                                    <div style="min-height: 300px !important; height: auto !important; overflow: auto;" class="dt-wrapper" style="overflow: auto;" >
                                                                        <table class="table table-striped table-bordered table-hover" data="{{TryXLfiltrate()}}">
                                                                            <thead>
                                                                                <tr>
                                                                                    <th ng-repeat="col in alarmsReport.cols" ng-show="col.id != 'idAlarm'" ng-style="{'min-width': col.css.min_width }">
                                                                                        <a>
                                                                                            <span>
                                                                                                {{col.name}}
                                                                                            </span>                                                                                                
                                                                                        </a>
                                                                                        <div ng-if="col.haveFilterFunctionality" class="dropdown" style="float: right">
                                                                                                <button class="dropdown-toggle filterdropdown" ng-class="{active:XLfilters.dict[col.id].isActive}" type="button" data-toggle="dropdown"><span class="glyphicon glyphicon-filter"></span></button>
                                                                                                <div class="dropdown-menu prop" aria-labelledby="btnSearchBatch" style="width: 250px; padding: 15px;">
                                                                                                  <div class="text-right">
                                                                                                    <a href="javascript:void(0);" class="filterlink" ng-click="clearFilter(col.id)">Limpar Filtro</a> | <a "javascript:void(0);" class="filterlink" data-dismiss="modal">Fechar(X)</a>
                                                                                                  </div>
                                                                                                  <form>
                                                                                                    <input type="text" class="form-control input-sm" ng-model="XLfilters.dict[col.id].searchText" placeholder="Filtrar" />
                                                                                                    <div>
                                                                                                      <a href="javascript:void(0);" class="filterlink" ng-click="markAll(col.id,true)">Selecionar Todos</a> | <a "javascript:void(0);" class="filterlink" ng-click="markAll(col.id,false)">Deselecionar Todos</a>
                                                                                                    </div>
                                                                                                    <div class="options">
                                                                                                            <ul style="list-style-type: none; padding: 0">
                                                                                                              <li ng-repeat="item in XLfilters.dict[col.id].options">
                                                                                                                <input id="{{col.id}}Option{{$index}}" type="checkbox" ng-model="XLfilters.dict[col.id].dict[item.title].checked" />&nbsp;<label for="{{col.id}}Option{{$index}}">{{item.title}}</label>
                                                                                                              </li>
                                                                                                            </ul>
                                                                                                          </div>
                                                                                                  </form>
                                                                                                </div>
                                                                                              </div>
                                                                                    </th>                                                                                        
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                    <tr ng-repeat="row in XLfilters.results.slice(((currentPageTab-1)*itemsPerPageTab), ((currentPageTab)*itemsPerPageTab))" ng-click="setSelectedRow(row.idAlarm)" ng-class="{customSelected: row.idAlarm === idSelectedRow}">
                                                                                            <td ng-repeat="columnName in row.Columns" ng-show="columnName != 'idAlarm'">
                                                                                                    {{row[columnName]}}    
                                                                                            </td>
                                                                                    </tr>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                    <div class="dt-row dt-bottom-row">
                                                                        <div class="row">
                                                                            <div class="col-sm-6">
                                                                                <div class="dataTables_info">Mostrando de {{itemPageStartTab}} até {{itemPageEndTab}} de {{totalItemsTab}} registros</div>
                                                                            </div>
                                                                            <div class="col-sm-6 text-right">
                                                                                <div class="dataTables_paginate paging_bootstrap_full">
                                                                                    <ul uib-pagination total-items="totalItemsTab" ng-model="currentPageTab" ng-change="pageChanged()" class="pagination-sm" items-per-page="itemsPerPageTab"></ul>
                                                                                </div> 
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>                                                               
                                                        </div>                                                      
                                                        <!-- end widget content -->
                                                    </div>                                                    
                                                    <!-- end widget div -->
                                            </div>
                                            <!-- end widget -->
                                        </article>
                                        <!-- WIDGET END -->
                                    </div>        
                                </section>                                                             
                            </div>
                            
                            <!-- Alarm History Tab -->
                            <div ng-class="{'tab-pane fade in active': selTab == 2, 'tab-pane fade': selTab != 2}" id="t2" >                                    
                                <section ng-widget-grid id="GridHist" class="">
                                    <!-- row -->
                                    <div class="row">
                                
                                        <!-- NEW WIDGET START -->
                                        <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
                                        
                                            <!-- Widget ID (each widget will need unique ID)-->
                                            <!-- <div class="jarviswidget jarviswidget-color-darken"  data-widget-deletebutton="false" data-widget-togglebutton="false" data-widget-collapsed="false" data-widget-fullscreenbutton="false" data-widget-editbutton="false" data-widget-colorbutton="false"> -->
                                                <div class="jarviswidget jarviswidget-color-greenDark"  data-widget-deletebutton="false" data-widget-togglebutton="false" data-widget-collapsed="false" data-widget-fullscreenbutton="false" data-widget-editbutton="false" data-widget-colorbutton="false">
                                            
                                                    <header>
                                                        <span class="widget-icon"> <i class="fa fa-table"></i> </span>
                                                        <h2></h2>
                                    
                                                    </header>
                                    
                                                    <!-- widget div-->
                                                    <div>
                                    
                                                        <!-- widget edit box -->
                                                        <div class="jarviswidget-editbox">
                                                            <!-- This area used as dropdown edit box -->
                                    
                                                        </div>
                                                        <!-- end widget edit box -->
                                    
                                                        <!-- widget content -->
                                                        <div class="widget-body no-padding">
                                                                <!-- <div class="widget-body-toolbar"> -->
                                                                <div class="widget-body-toolbar">
                                                                        <div class="widget-toolbar smart-form">
                                                                                <a class="btn btn-primary" ng-click="LoadTabInfo(selTab)"><i class="fa fa-refresh"></i></a>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form">
                                                                                <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                                                                    <input style="width: 120px" type="text" name="txtDateEnd" ng-model="endDate"  placeholder="Data Final" ng-date-picker  data-dateformat="dd/mm/yy" id="dp112">
                                                                                </label>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form">                                                        
                                                                                <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                                                                    <input style="width: 120px" type="text" name="txtDateStart" ng-model="startDate" placeholder="Data inicial"   ng-date-picker  data-dateformat="dd/mm/yy" id="dp111">                                
                                                                                </label>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form">
                                                                                <span><i class="fa fa-filter"></i> Filtrar:</span>
                                                                        </div>
                                                                        <div excel-export export-data="exportData" style="float: right !important;" file-name="{{fileName}}"></div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important;">
                                                                            <span>Registros por Página:</span>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important; border-left: none !important; padding-right: 8px !important; padding-left: 0px !important;">
                                                                                <label class="select" style="width:60px">
                                                                                        <select size="1" ng-model="viewbyTab2" ng-change="setItemsPerPageTab2(viewbyTab2)" name="dt_basic_length" aria-controls="dt_basic">
                                                                                            <option value="5">5</option>
                                                                                            <option value="10">10</option>
                                                                                            <option value="25">25</option>
                                                                                            <option value="50">50</option>
                                                                                            <option value="100">100</option>
                                                                                        </select><i></i>
                                                                                </label>
                                                                        </div>
                                                                        <div class="widget-toolbar smart-form" style="float: left !important; border-right: 1px solid rgba(0, 0, 0, 0.09) !important;">
                                                                            <span ng-click="clearAll();"><i class="fa fa-undo"></i>Limpar Filtros</span>
                                                                        </div>                                                                        
                                                                        <!-- <div class="widget-toolbar smart-form" style="float: left !important; border-right: 1px solid rgba(0, 0, 0, 0.09) !important;">
                                                                                <label class="toggle" style="font-size: 13px !important; line-height: 32px !important;">
                                                                                        <input type="checkbox" name="checkbox-toggle" checked="checked" ng-model="onlyActives" ng-disabled="false">
                                                                                        <i data-swchon-text="SIM" data-swchoff-text="NÃO"></i>Só chamados Ativos
                                                                                </label>  
                                                                        </div> -->
                                                                </div>                                                                    
                                                                <div class="dataTables_wrapper form-inline" role="grid">
                                                                    <div style="min-height: 300px !important; height: auto !important; overflow: auto;" class="dt-wrapper" style="overflow: auto;" >
                                                                        <table class="table table-striped table-bordered table-hover" data="{{TryXLfiltrate()}}">
                                                                            <thead>
                                                                                <tr>
                                                                                    <th ng-repeat="col in alarmsHistory.cols" ng-show="col.id != 'idAlarmHistory'" ng-style="{'min-width': col.css.min_width }">
                                                                                        <a>
                                                                                            <span>
                                                                                                {{col.name}}
                                                                                            </span>                                                                                                
                                                                                        </a>
                                                                                        <div ng-if="col.haveFilterFunctionality" class="dropdown" style="float: right">
                                                                                                <button class="dropdown-toggle filterdropdown" ng-class="{active:XLfilters.dict[col.id].isActive}" type="button" data-toggle="dropdown"><span class="glyphicon glyphicon-filter"></span></button>
                                                                                                <div class="dropdown-menu prop" aria-labelledby="btnSearchBatch" style="width: 250px; padding: 15px;">
                                                                                                  <div class="text-right">
                                                                                                    <a href="javascript:void(0);" class="filterlink" ng-click="clearFilter(col.id)">Limpar Filtro</a> | <a "javascript:void(0);" class="filterlink" data-dismiss="modal">Fechar(X)</a>
                                                                                                  </div>
                                                                                                  <form>
                                                                                                    <input type="text" class="form-control input-sm" ng-model="XLfilters.dict[col.id].searchText" placeholder="Filtrar" />
                                                                                                    <div>
                                                                                                      <a href="javascript:void(0);" class="filterlink" ng-click="markAll(col.id,true)">Selecionar Todos</a> | <a "javascript:void(0);" class="filterlink" ng-click="markAll(col.id,false)">Deselecionar Todos</a>
                                                                                                    </div>
                                                                                                    <div class="options">
                                                                                                            <ul style="list-style-type: none; padding: 0">
                                                                                                              <li ng-repeat="item in XLfilters.dict[col.id].options">
                                                                                                                <input id="{{col.id}}Option{{$index}}" type="checkbox" ng-model="XLfilters.dict[col.id].dict[item.title].checked" />&nbsp;<label for="{{col.id}}Option{{$index}}">{{item.title}}</label>
                                                                                                              </li>
                                                                                                            </ul>
                                                                                                          </div>
                                                                                                  </form>
                                                                                                </div>
                                                                                              </div>
                                                                                    </th>                                                                                        
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                    <tr ng-repeat="row in XLfilters.results.slice(((currentPageTab2-1)*itemsPerPageTab2), ((currentPageTab2)*itemsPerPageTab2))">
                                                                                            <td ng-repeat="columnName in row.Columns" ng-show="columnName != 'idAlarmHistory'">
                                                                                                    {{row[columnName]}}    
                                                                                            </td>
                                                                                    </tr>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                    <div class="dt-row dt-bottom-row">
                                                                        <div class="row">
                                                                            <div class="col-sm-6">
                                                                                <div class="dataTables_info">Mostrando de {{itemPageStartTab2}} até {{itemPageEndTab2}} de {{totalItemsTab2}} registros</div>
                                                                            </div>
                                                                            <div class="col-sm-6 text-right">
                                                                                <div class="dataTables_paginate paging_bootstrap_full">
                                                                                    <ul uib-pagination total-items="totalItemsTab2" ng-model="currentPageTab2" ng-change="pageChanged()" class="pagination-sm" items-per-page="itemsPerPageTab2"></ul>
                                                                                </div> 
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>                                                               
                                                        </div>                                                      
                                                        <!-- end widget content -->
                                                    </div>                                                    
                                                    <!-- end widget div -->
                                            </div>
                                            <!-- end widget -->
                                        </article>
                                        <!-- WIDGET END -->
                                    </div>        
                                </section>                                                             
                            </div>

                        </div>
                    </div>
                    <!-- end widget content -->
                </div>
                <!-- end widget div -->
            </div>
            <!-- end widget -->                                  
        </article>
        <!-- WIDGET END -->
    </div>
 </section>
