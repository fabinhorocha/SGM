                    //                 [{ text: "Tipo 1", fillStyle: "rgb(0, 0, 153)" }, { text: "Tipo 2", fillStyle: "rgb(204, 0, 102)" }, { text: "Tipo 3", fillStyle: "rgb(0,153,0)" }, { text: "Tipo 4", fillStyle: "rgb(255,0,0)" }]
