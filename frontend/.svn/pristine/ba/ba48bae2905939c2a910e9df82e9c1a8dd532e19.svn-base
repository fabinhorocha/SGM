                { "mDataProp": "Analizada", "aTargets":[12] },      
                { "mDataProp": "Concluída não Finalizada", "aTargets":[13] }, 
                { "mDataProp": "Concluída no Prazo", "aTargets":[14] },
                { "mDataProp": "Concluída Fora do Prazo", "aTargets":[15] }                         
    ]; 
    

    $scope.fillChart = function (scope){        
        
        var workCenter = scope.failureWorkCenter == null ? null : scope.failureWorkCenter.Sheet;
        if(scope.failureEquipment != null)
            GetNotesFailure(scope.startDate, scope.endDate, scope.failureEquipment.Sheet, workCenter);
        else
            if(scope.failureArea != null)
                GetNotesFailure(scope.startDate, scope.endDate, scope.failureArea.Sheet, workCenter);
            else
                if(scope.failureFactory != null)
                    GetNotesFailure(scope.startDate, scope.endDate, scope.failureFactory.Sheet, workCenter);
 
       
    };
    
 
    function GetNotesFailure(dateStart, dateEnd, location, centerCost){
        
        indicatorFailureAnalyzedFactory.GetNotesFailure(dateStart, dateEnd, location, centerCost).success(function (response){                
            
            $scope.FailureAnalyzedDataAll = response;

            if(response.length > 0)  
                FillChart();

                              
        }).error(function(error){

            $.bigBox({
            title : "Erro!",
            content : error ? error.Message : "Falha de comunicação com o servidor.",            
            color : "#C46A69",              
            icon : "fa fa-warning swing animated",              
            timeout : 6000 });

        });    
    };

    function FillChart(){
        
        var failureAnalyzedData = angular.copy($scope.FailureAnalyzedDataAll);        

        //Series
        var series = [
            { id: 1, name: 'M2 Tipo 1' }, 
            { id: 2, name: 'M2 Tipo 2' },
            { id: 3, name: 'M2 Tipo 3' }, 
            { id: 4, name: 'M2 Tipo 4' },
            { id: 5, name: 'FA Pendente' }, 
            { id: 6, name: 'FA Aberta' },
            { id: 7, name: 'FA Analizada' }, 
            { id: 8, name: 'FA Concluída não Finalizada' },
            { id: 9, name: 'FA Concluída no Prazo' },
            { id: 10, name: 'FA Concluída Fora do Prazo' }
        ];

        //DataSetOverride
        var type1Color = 'rgb(231, 230, 230)';
        var type2Color = 'rgb(175, 171, 171)';
        var type3Color = 'rgb(59, 56, 56)';
        var type4Color = 'rgb(69, 85, 107)';

        var type5Color = 'rgb(192, 0, 0)';
        var type6Color = 'rgb(255, 255, 0)';
        var type7Color = 'rgb(189, 215, 238)';
        var type8Color = 'rgb(132, 151, 176)';
        var type9Color = 'rgb(167, 205, 149)';
        var type10Color = 'rgb(101, 111, 89)';
        

        var datasetOverride = [ 
            { stack: 1, label: 'M2 Tipo 1', fill: true, backgroundColor: type1Color, borderColor: type1Color, pointBackgroundColor: type1Color, pointBorderColor: '#fff', pointHoverBackgroundColor: type1Color, pointHoverBorderColor: type1Color },
            { stack: 1, label: 'M2 Tipo 2', fill: true, backgroundColor: type2Color, borderColor: type2Color, pointBackgroundColor: type2Color, pointBorderColor: '#fff', pointHoverBackgroundColor: type2Color, pointHoverBorderColor: type2Color, },
            { stack: 1, label: 'M2 Tipo 3', fill: true, backgroundColor: type3Color, borderColor: type3Color, pointBackgroundColor: type3Color, pointBorderColor: '#fff', pointHoverBackgroundColor: type3Color, pointHoverBorderColor: type3Color},
            { stack: 1, label: 'M2 Tipo 4', fill: true, backgroundColor: type4Color, borderColor: type4Color, pointBackgroundColor: type4Color, pointBorderColor: '#fff', pointHoverBackgroundColor: type4Color, pointHoverBorderColor: type4Color },
            { stack: 2, label: 'FA Pendente', fill: true, backgroundColor: type5Color, borderColor: type5Color, pointBackgroundColor: type5Color, pointBorderColor: '#fff', pointHoverBackgroundColor: type5Color, pointHoverBorderColor: type5Color },
            { stack: 2, label: 'FA Aberta', fill: true, backgroundColor: type6Color, borderColor: type6Color, pointBackgroundColor: type6Color, pointBorderColor: '#fff', pointHoverBackgroundColor: type6Color, pointHoverBorderColor: type6Color, },
            { stack: 2, label: 'FA Analizada', fill: true, backgroundColor: type7Color, borderColor: type7Color, pointBackgroundColor: type7Color, pointBorderColor: '#fff', pointHoverBackgroundColor: type7Color, pointHoverBorderColor: type7Color},
            { stack: 2, label: 'FA Concluída não Finalizada', fill: true, backgroundColor: type8Color, borderColor: type8Color, pointBackgroundColor: type8Color, pointBorderColor: '#fff', pointHoverBackgroundColor: type8Color, pointHoverBorderColor: type8Color },
            { stack: 2, label: 'FA Concluída no Prazo', fill: true, backgroundColor: type9Color, borderColor: type9Color, pointBackgroundColor: type9Color, pointBorderColor: '#fff', pointHoverBackgroundColor: type9Color, pointHoverBorderColor: type9Color},
            { stack: 2, label: 'FA Concluída Fora do Prazo', fill: true, backgroundColor: type10Color, borderColor: type10Color, pointBackgroundColor: type10Color, pointBorderColor: '#fff', pointHoverBackgroundColor: type10Color, pointHoverBorderColor: type10Color }

        ];

        //Fill Labels
        var labels = FillLabels(failureAnalyzedData);

        //Fill Data
        var chartAnalyzed = FillData(failureAnalyzedData, series, labels);

         //Render Chart
        RenderChart(chartAnalyzed, series, datasetOverride, labels);
    }

    function FillLabels(failureAnalyzedData) {

        var labels = [];
                
        angular.forEach(failureAnalyzedData, function(obj, key){                                         

            if(obj.dateRef){
                var label = $filter('date')(obj.dateRef,'MM/yyyy');
                var labelExist = labels.filter(function(e){ return e ===  label;});
                if(labelExist.length == 0)                    
                    labels.push(label);
            }

        });
               
        return labels;
    }

    function FillData(failureAnalyzedData, series, labels){

        var chartAnalyzed = [];
        //Data
        angular.forEach(series, function (serie, index) {

            var values = [];
            angular.forEach(labels, function (label, index) {          

                var failureAnalyzedDataByType = FilterFailureAnalyzedDataByType(failureAnalyzedData, serie.id, label);

                if (failureAnalyzedDataByType.length > 0)
                    angular.forEach(failureAnalyzedDataByType, function (item, index) {
                                      
                        var label = $filter('date')(item.dateRef,'MM/yyyy');;
                        var valuesByLabel = values.filter(function (e) { return e.Label === label })[0];
                            if (valuesByLabel) {
                                valuesByLabel.Qty += 1;                                
                                valuesByLabel.Details.push(item);
                            }
                            else
                                values.push({ Label: label, Qty: 1, Details: [item] })
                    });
                else
                    values.push({ Label: label, Qty: 0, Seconds: 0, Details: [] })
            });

            chartAnalyzed.push({ serie: serie.name, values: values});
        });

        return chartAnalyzed;
    }

    function FilterFailureAnalyzedDataByType(failureAnalyzedData, serie, label){

        var filterFailure = [];
        if(serie <= 4)
            filterFailure = failureAnalyzedData.filter(function (e) { return e.cdTypeOperation === serie && $filter('date')(e.dateRef,'MM/yyyy') === label });
        else{
            switch(serie){

                case 5: 
                    filterFailure = failureAnalyzedData.filter(function (e) { return e.cdPendingFA === 1 && $filter('date')(e.dateRef,'MM/yyyy') === label });
                    break;
                case 6: 
                    filterFailure = failureAnalyzedData.filter(function (e) { return e.cdOpenFA === 1 && $filter('date')(e.dateRef,'MM/yyyy') === label });
                    break;
                case 7: 
                    filterFailure = failureAnalyzedData.filter(function (e) { return e.cdAnalyzedFA === 1 && $filter('date')(e.dateRef,'MM/yyyy') === label });
                    break;
                case 8: 
                    filterFailure = failureAnalyzedData.filter(function (e) { return e.cdClosedNotEndFA === 1 && $filter('date')(e.dateRef,'MM/yyyy') === label });
                    break;
                case 9: 
                    filterFailure = failureAnalyzedData.filter(function (e) { return e.cdClosedOnTimeFA === 1 && $filter('date')(e.dateRef,'MM/yyyy') === label });
                    break;
                case 10: 
                    filterFailure = failureAnalyzedData.filter(function (e) { return e.cdClosedDelayFA === 1 && $filter('date')(e.dateRef,'MM/yyyy') === label });
                    break;
                default:
                    break;
            }
        }

        return filterFailure;
    }

    function RenderChart(chartAnalyzed, series, datasetOverride, labels){
        var data = [];
        var detailsAnalyzed = [];

        angular.forEach(chartAnalyzed, function (serie, index) {

            var values = [];
            var details = [];                      

            angular.forEach(serie.values, function (value, indexValue) {
                                           
                values.push(value.Qty);
               
                if (value.Qty > 0) {                    
                    angular.forEach(value.Details, function (detail, indexValue) {                        
                        details.push(detail);                           
                    });                                       
                }
            });            

            data.push(values);
            detailsAnalyzed.push({ title: serie.serie, details: details });

         
        });


        $scope.failureAnalyzedData = {
            series: series,
            datasetOverride: datasetOverride,
            labels: labels,
            data: data,
            detailsAnalyzed: detailsAnalyzed,            
        }

       
    }

    function GetEquipmentsPlantGroup(index, sheedMan){
        
       
        equipmentPlantGroupFactory.GetEquipmentsPlantGroup(index, sheedMan).success(function (response){                
            
            if(response.length > 0)  {

                switch(index){                    
                    case 2 :
                        $scope.failureFactories = response;
                        $scope.failureAreas = [];
                        $scope.failureEquipments = [];
                    break;
                    case 3 :
                        $scope.failureAreas = response;
                        $scope.failureEquipments= [];
                    break;
                    case 4 :
                        $scope.failureEquipments = response;
                    break;
                }

            }                                                 
                            
                               
        }).error(function(error){

            $.bigBox({
            title : "Erro!",
            content : error ? error.Message : "Falha de comunicação com o servidor.",            
            color : "#C46A69",              
            icon : "fa fa-warning swing animated",              
            timeout : 6000 });
          
        });    


        
    };
             
      
});    




