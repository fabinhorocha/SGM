<div class="row">
        <div class="col-xs-12 col-sm-7 col-md-7 col-lg-6 text-align-left" style="height: 45px !important;"> 
            <h1 class="page-title txt-color-blueDark"><i class="fa-fw fa fa-bar-chart-o"></i>                                 
                Indicadores 
                <span>>
                    {{Title}}
                </span>
            </h1>    
                                                     
        </div> 
</div>
<div class="row">
        <section class="col col-lg-3">
            <select id="selectedFactory" name="selectedFactory"
            ng-model="oilFactory" 
            chosen
            options="oilFactories" 
            ng-options="f.Name for f in oilFactories" 
            style="width: 240px !important;"
            ng-change="selectedLevelMenuChange(1)"
            data-placeholder="SELECIONE">
            </select>    
        </section>
        <section class="col col-lg-3">
            <select id="selectedArea" name="selectedArea"
            ng-model="oilArea" 
            chosen
            options="oilAreas" 
            ng-options="a.Name for a in oilAreas" 
            style="width: 240px !important;"
            ng-change="selectedLevelMenuChange(2)"
            data-placeholder="SELECIONE">
            </select>    
        </section>
        <section class="col col-lg-3">
            <select id="selectedEquipment" name="selectedEquipment"
            ng-model="oilEquipment" 
            chosen
            options="oilEquipments" 
            ng-options="e.Name for e in oilEquipments" 
            style="width: 240px !important;"
            ng-change="selectedLevelMenuChange(3)"
            data-placeholder="SELECIONE">
            </select>    
        </section>
        <section class="col col-lg-3">
            <select id="selectedComponent" name="selectedComponent" class="form-control"
            ng-model="oilComponent" 
            chosen
            options="oilComponents" 
            ng-options="c.Name for c in oilComponents" 
            style="width: 240px !important;"
            ng-change="selectedLevelMenuChange(4)"
            data-placeholder="SELECIONE">
            </select>    
        </section>
 </div>
<div class="col-lg-12 text-right" style="margin-bottom: 5px; margin-top: 5px;">
    <div class="widget-toolbar smart-form">
            <a class="btn btn-primary" ng-click="refreshGraphic()"><i class="fa fa-refresh"></i></a>
    </div>
    <div class="widget-toolbar smart-form">
            <button class="btn btn-default" style="font: 300 15px/29px 'Open Sans', Helvetica, Arial, sans-serif !important; padding-bottom: 0px !important; padding-top: 0px !important;" 
        ng-click="clearFilters()">
        <i class="fa fa-undo"></i> <span class="hidden-mobile">Limpar Filtros Selecinados</span>
        </button>
    </div>
    <div class="widget-toolbar smart-form">
        <label class="input"> <i class="icon-append fa fa-calendar"></i>
            <input style="width: 120px" type="text" name="txtDateEnd" ng-model="endDate"  placeholder="Data Final" ng-date-picker  data-dateformat="dd/mm/yy" id="dp112">
        </label>
    </div>
    <div class="widget-toolbar smart-form">                                                        
        <label class="input"> <i class="icon-append fa fa-calendar"></i>
            <input style="width: 120px" type="text" name="txtDateStart" ng-model="startDate" placeholder="Data inicial"   ng-date-picker  data-dateformat="dd/mm/yy" id="dp111">                                
        </label>
    </div>
    <div class="widget-toolbar smart-form">
        <label class="select">
            <select id="selectedReportType" name="selectedReportType"
            class="form-control" 
            ng-model="reporType"
            style="width: 90px !important;" 
            ng-options="rt.Name for rt in reportsType"
            ng-change="refreshGraphic()">
            </select>
            <i></i> 
        </label>
    </div>
    <div class="widget-toolbar smart-form">
        <span><i class="fa fa-filter"></i>Tipo Gráfico:</span>
    </div>
</div>
<div class="panel-group" id="accordion">
    <div class="panel panel-default">
        <div class="panel-heading" style="padding: 3px 15px !important;">
        <h4 class="panel-title">
            <a href="javascript:;" style="font-size: 10pt;" data-toggle="collapse" data-parent="#accordion" data-target="#collapseOne">
            Filtros avançados
            </a>
        </h4>
        </div>
        <div id="collapseOne" class="panel-collapse collapse in">
            <div class="panel-body" style="padding: 3px !important;">
                <div class="widget-toolbar smart-form">
                    <label class="select">
                        <select id="selectedStoppageType" name="selectedStoppageType"
                        class="form-control" 
                        ng-model="stoppageType"
                        style="width: 120px !important;" 
                        ng-options="st.Name for st in model.StoppageTypes"
                        ng-change="refreshGraphic()">
                        </select>
                        <i></i> 
                    </label>
                </div>
                <div class="widget-toolbar smart-form">
                    <span><i class="fa fa-filter"></i>Gerou Parada:</span>
                </div>
                <div class="widget-toolbar smart-form">
                    <label class="select">
                        <select id="selectedOilSupplyType" name="selectedOilSupplyType"
                        class="form-control" 
                        ng-model="oilSupplyType"
                        style="width: 120px !important;" 
                        ng-options="os.Name for os in model.OilSupplyTypes"
                        ng-change="refreshGraphic()">
                        </select>
                        <i></i> 
                    </label>
                </div>
                <div class="widget-toolbar smart-form">
                    <span><i class="fa fa-filter"></i>Tipo de Abastecimento:</span>
                </div>
                <div class="widget-toolbar smart-form">
                    <label class="select">
                        <select id="selectedOilType" name="selectedOilType"
                        class="form-control" 
                        ng-model="oilType"
                        style="width: 120px !important;" 
                        ng-options="ot.Name for ot in model.OilTypes"
                        ng-change="refreshGraphic()">
                        </select>
                        <i></i> 
                    </label>
                </div>
                <div class="widget-toolbar smart-form">
                    <span><i class="fa fa-filter"></i>Tipo de Óleo:</span>
                </div>
            </div>
        </div>
    </div>
</div>
    
<!-- widget grid -->
<section id="widget-grid-indicatorOil"  ng-repeat="row in oilManagementData" ng-widget-grid class="">
    <div class="row" ng-include src="'views/contentIndicatorsOilManagement.html'">
    </div>  
</section>
<!-- end widget grid -->
    