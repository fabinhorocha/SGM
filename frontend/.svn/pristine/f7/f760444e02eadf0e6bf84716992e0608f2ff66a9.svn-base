<div class="row">
        <div class="col-xs-12 col-sm-7 col-md-7 col-lg-12">
            <h1 class="page-title txt-color-blueDark"><i class="fa-fw fa fa-table"></i> 
                
                
                Indicadores
                <span>>
                Budget
                </span>
            </h1>    
                <!-- Laudos <span></span></h1> -->
        </div>        
</div>

<section id="widget-grid-budget" ng-widget-grid class=""> 
        
        <div class="row">
             <!-- NEW WIDGET START -->
             <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
                 
                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget jarviswidget-color-darken"  data-widget-deletebutton="false" data-widget-togglebutton="false" data-widget-collapsed="false" data-widget-fullscreenbutton="false" data-widget-editbutton="false" data-widget-colorbutton="false">
               
                    <header>
                        <span class="widget-icon"> <i class="fa fa-edit"></i> </span>
                        <h2></h2>				
                     
                    </header>

                    <!-- widget div-->
                    <div>
                    
                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->
                            
                        </div>
                        <!-- end widget edit box -->
                        
                        <!-- widget content -->
                        <div class="widget-body no-padding" >
                          
                            <!-- <div ng-include src="'views/formReport.html'"></div> -->
                            <form id="reportForm"  name="reportForm" class="smart-form"  ng-submit="saveBudget(Budget)">                                                      
                                                                       
                                <fieldset>
                                    <ul id="myTabBudget" class="nav nav-tabs bordered">            
                                
                                            <li ng-repeat="t in tabsBudget" ng-class="{'active': selTabBudget == t.id}">
                                                    <a href="#tBudget{{t.id}}"  target="_self" data-toggle="tab" ng-click= "setTabBudget(t.id)"><i class={{t.class}}></i>{{t.name}}</a>                                   
                                            </li>
                                            
                                    </ul>
                                    <div id="myTabBudgetContent1" class="tab-content padding-10">
                                            <div  ng-class="{'tab-pane fade in active': selTabBudget == 1, 'tab-pane fade': selTabBudget != 1}" id="tBudget1">
                                                
                                                            <div class="row">
                                                                    <section class="col col-3">
                                                                            
                                                                            <label class="label">Data de Início</label>
                                                                            <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                                                                <input type="text" name="txtDateStart" ng-model="Budget.dateStart"  ng-date-picker  data-dateformat="dd/mm/yy" id="txtDateStart" required>
                                                                            </label>
                                                                                
                                                                    </section>
                                                                    <section class="col col-3">
                                                                            
                                                                            <label class="label">Data de Fim</label>
                                                                            <label class="input"> <i class="icon-append fa fa-calendar"></i>
                                                                                <input type="text" name="txtDateEnd" ng-model="Budget.dateEnd"  ng-date-picker  data-dateformat="dd/mm/yy" id="txtDateEnd" required>
                                                                            </label>
                                                                                
                                                                    </section>
                                                                    
                                                            </div>    
                                                           
                                                       
                                                            <section>
                                                                        <ul id="myTabBudgetDetails" class="nav nav-tabs bordered">
                                                                                        
                                                                                <li class="active">
                                                                                        <a href="#tTablePrev"  target="_self" data-toggle="tab" ng-click="setPageGoal(1)"></i>Preventivas</a>                                                                    
                                                                                </li>
                                                                                <li>                                    
                                                                                        <a  href="#tTablePred" target="_self" data-toggle="tab"  ng-click="setPageGoal(1)"></i>Preditivas</a>                                                                
                                                                                </li>
                                                                                <li>                                    
                                                                                        <a  href="#tTableOT" target="_self" data-toggle="tab"  ng-click="setPageGoal(1)"></i>OT's</a>                                                                
                                                                                </li>
                                                                                <li>                                    
                                                                                        <a  href="#tTableOTPred" target="_self" data-toggle="tab"  ng-click="setPageGoal(1)"></i>OT's (Preditiva)</a>                                                                
                                                                                </li>
                                                                                                                
                                                                                        
                                                                        </ul>
                                                                        <div id="myTabBudgetDetailsContent1" class="tab-content padding-10">
                                                                                        <div class="tab-pane fade in active" id="tTablePrev">
                                                                                                <div class="dataTables_wrapper form-inline" role="grid">
                                                                                                                                                                                
                                                                                                        <div class="dt-wrapper">
                                                                                                                <table class="table table-striped table-bordered table-hover">
                                                                                                                        <thead>
                                                                                                                                <th style="text-align: center" colspan="6">Metas</th>
                                                                                                                        </thead>
                                                                                                                        <thead>
                                                                                                                                <th>Status</th>
                                                                                                                                <th>Planta</th>
                                                                                                                                <th>Local</th>                                                                                            
                                                                                                                                <th style="text-align: center">Preventiva</th>                                                                                                                        
                                                                                                                                                                                                                                                                                                
                                                                                                                        </thead>
                                                                                                                        <tbody>
                                                                                                                                
                                                                                                                                <tr ng-repeat="row in Budget.budgetLocationsPrev.slice(((goalcurrentPage-1)*goalitemsPerPage), ((goalcurrentPage)*goalitemsPerPage))" >
                                                                                                                                        
                                                                                                                                       
                                                                                                                                        <td style="text-align: left;width:25px">
                                                                                                                                                <label class="toggle">
                                                                                                                                                        <input type="checkbox" name="checkbox-toggle" checked="checked" ng-model="row.Active" >
                                                                                                                                                        <i data-swchon-text="ON" data-swchoff-text="OFF"></i>
                                                                                                                                                </label>  
                                                                                                                                        </td>
                                                                                                                                        <td>
                                                                                                                                                <label class="label">{{row.LocationPlant.Plant.Sheet}} - {{row.LocationPlant.Plant.Name}}</label>     
                                                                                                                                        </td>
                                                                                                                                        <td>
                                                                                                                                                <label class="label">{{row.LocationPlant.Location.Sheet}} - {{row.LocationPlant.Location.Name}}</label>     
                                                                                                                                        </td>
                                                                                                                                
                                                                                                                                        <td style="text-align: center;width:70px">
                                                                                                                                                <label class="input" >										                        
                                                                                                                                                        <input type="number" min="0" value="0" step="000" name="txtVlGoalPrev" ng-model="row.vlGoal"/>
                                                                                                                                                </label>     
                                                                                                                                        </td>
                                                                                                                                       
                                                                                                                                </tr>
                                                
                                                                                                                                
                                                                                                                        </tbody>
                                                                                                                
                                                                                                                </table>
                                                                                                        </div>
                                                                                                        <div class="dt-row dt-bottom-row">
                                                                                                                <div class="row">
                                                                                                                <section class="col col-6">
                                                                                                                        <div class="dataTables_info">Mostrando de {{goalitemPageStart}} até {{goalitemPageEnd}} de {{goaltotalItemsPrev}} registros</div>
                                                                                                                </section>
                                                                                                                <section class="col col-6 text-right">
                                                                                                                        <div class="dataTables_paginate paging_bootstrap_full">
                                                                                                                        <ul uib-pagination total-items="goaltotalItemsPrev" ng-model="goalcurrentPage" ng-change="pageChanged()" class="pagination-sm" items-per-page="goalitemsPerPage"></ul>
                                                                                                                        </div>
                                                                                                                </section>
                                                                                                                </div>
                                                                                                        </div>
                                                                                                </div>            
                                                                                        </div>
                                                                                        <div class="tab-pane" id="tTablePred">
                                                                                                        <div class="dataTables_wrapper form-inline" role="grid">
                                                                                                                                                                                        
                                                                                                                <div class="dt-wrapper">
                                                                                                                        <table class="table table-striped table-bordered table-hover">
                                                                                                                        <thead>
                                                                                                                                <th style="text-align: center" colspan="6">Metas</th>
                                                                                                                        </thead>
                                                                                                                        <thead>
                                                                                                                                <th>Status</th>
                                                                                                                                <th>Planta</th>
                                                                                                                                <th>Local</th>                                                                                                                                                                                                                            
                                                                                                                                <th style="text-align: center">Preditiva</th>
                                                                                                                                                                                                                                                                                                
                                                                                                                        </thead>
                                                                                                                        <tbody>
                                                                                                                                
                                                                                                                                <tr ng-repeat="row in Budget.budgetLocationsPred.slice(((goalcurrentPage-1)*goalitemsPerPage), ((goalcurrentPage)*goalitemsPerPage))">                                                                                                                                        
                                                                                                                                                <td style="text-align: left;width:25px">
                                                                                                                                                        <label class="toggle">
                                                                                                                                                                <input type="checkbox" name="checkbox-toggle" checked="checked" ng-model="row.Active" >
                                                                                                                                                                <i data-swchon-text="ON" data-swchoff-text="OFF"></i>
                                                                                                                                                        </label>  
                                                                                                                                                </td>
                                                                                                                                                <td>
                                                                                                                                                        <label class="label">{{row.LocationPlant.Plant.Sheet}} - {{row.LocationPlant.Plant.Name}}</label>     
                                                                                                                                                </td>
                                                                                                                                                <td>
                                                                                                                                                        <label class="label">{{row.LocationPlant.Location.Sheet}} - {{row.LocationPlant.Location.Name}}</label>     
                                                                                                                                                </td>
                                                                                                                                                <!-- <td style="text-align: center;width:70px"> 
                                                                                                                                                        <label class="input">										                        
                                                                                                                                                        <input  type="number" min="0" value="0" step="000" name="txtVlGoal" ng-model="row.vlGoal"/>
                                                                                                                                                        </label>  
                                                                                                                                                </td> -->
                                                                                                                                                <!-- <td style="text-align: center;width:70px">
                                                                                                                                                        <label class="input" ng-if="row.LocationPlant.Plant.Sheet != 'CF9' && row.LocationPlant.Plant.Sheet != 'SR9'">										                        
                                                                                                                                                                <input type="number" min="0" value="0" step="000" name="txtVlGoalPrev" ng-model="row.vlGoal"/>
                                                                                                                                                        </label>     
                                                                                                                                                </td> -->
                                                                                                                                                <td style="text-align: center;width:70px">
                                                                                                                                                        <label class="input">										                        
                                                                                                                                                                <input type="number"  min="0" value="0" step="000" name="txtVlGoalPred" ng-model="row.vlGoal"/>
                                                                                                                                                        </label>
                                                                                                                                                </td>                                                                                                                                        
                                                                                                                                </tr>
                                                
                                                                                                                                
                                                                                                                        </tbody>
                                                                                                                        
                                                                                                                        </table>
                                                                                                                </div>
                                                                                                                <div class="dt-row dt-bottom-row">
                                                                                                                        <div class="row">
                                                                                                                        <section class="col col-6">
                                                                                                                                <div class="dataTables_info">Mostrando de {{goalitemPageStart}} até {{goalitemPageEnd}} de {{goaltotalItemsPred}} registros</div>
                                                                                                                        </section>
                                                                                                                        <section class="col col-6 text-right">
                                                                                                                                <div class="dataTables_paginate paging_bootstrap_full">
                                                                                                                                <ul uib-pagination total-items="goaltotalItemsPred" ng-model="goalcurrentPage" ng-change="pageChanged()" class="pagination-sm" items-per-page="goalitemsPerPage"></ul>
                                                                                                                                </div>
                                                                                                                        </section>
                                                                                                                        </div>
                                                                                                                </div>
                                                                                                        </div>            
                                                                                                </div>
                                                                                        <div class="tab-pane" id="tTableOT">
                                                                                                <div class="dataTables_wrapper form-inline" role="grid">
                                                                                                                                                                                
                                                                                                        <div class="dt-wrapper">
                                                                                                                <table class="table table-striped table-bordered table-hover">
                                                                                                                        <thead>
                                                                                                                                <th style="text-align: center" colspan="6">Metas</th>
                                                                                                                        </thead>
                                                                                                                        <thead>
                                                                                                                                <th>Status</th>
                                                                                                                                <th>Planta</th>                                                                                                                                                       
                                                                                                                                <th style="text-align: center">OT</th>                                                                
                                                                                                                                                                                                                                                                                                
                                                                                                                        </thead>
                                                                                                                        <tbody>
                                                                                                                                
                                                                                                                                <tr ng-repeat="row in Budget.budgetPlants.slice(((goalcurrentPage-1)*goalitemsPerPage), ((goalcurrentPage)*goalitemsPerPage))">
                                                                                                                                        <td style="text-align: left;width:25px">
                                                                                                                                                <label class="toggle">
                                                                                                                                                        <input type="checkbox" name="checkbox-toggle" checked="checked" ng-model="row.Active" >
                                                                                                                                                        <i data-swchon-text="ON" data-swchoff-text="OFF"></i>
                                                                                                                                                </label>  
                                                                                                                                        </td>
                                                                                                                                        <td>
                                                                                                                                                <label class="label">{{row.Plant.Sheet}} - {{row.Plant.Name}}</label>     
                                                                                                                                        </td>
                                                                                                                                
                                                                                                                                        <td style="text-align: center;width:70px"> 
                                                                                                                                                <label class="input">										                        
                                                                                                                                                <input  type="number" min="0" value="0" step="000" name="txtVlGoal" ng-model="row.vlGoal"/>
                                                                                                                                                </label>  
                                                                                                                                        </td>
                                                                                                                                
                                                                                                                                </tr>

                                                                                                                                
                                                                                                                        </tbody>
                                                                                                                
                                                                                                                </table>
                                                                                                        </div>
                                                                                                        <div class="dt-row dt-bottom-row">
                                                                                                                <div class="row">
                                                                                                                <section class="col col-6">
                                                                                                                        <div class="dataTables_info">Mostrando de {{goalitemPageStart}} até {{goalitemPageEnd}} de {{goaltotalItems}} registros</div>
                                                                                                                </section>
                                                                                                                <section class="col col-6 text-right">
                                                                                                                        <div class="dataTables_paginate paging_bootstrap_full">
                                                                                                                        <ul uib-pagination total-items="goaltotalItems" ng-model="goalcurrentPage" ng-change="pageChanged()" class="pagination-sm" items-per-page="goalitemsPerPage"></ul>
                                                                                                                        </div>
                                                                                                                </section>
                                                                                                                </div>
                                                                                                        </div>
                                                                                                 </div>      
                                                                                        </div>
                                                                                        <div class="tab-pane" id="tTableOTPred">
                                                                                                        <div class="dataTables_wrapper form-inline" role="grid">
                                                                                                                                                                                        
                                                                                                                <div class="dt-wrapper">
                                                                                                                        <table class="table table-striped table-bordered table-hover">
                                                                                                                                <thead>
                                                                                                                                        <th style="text-align: center" colspan="6">Metas</th>
                                                                                                                                </thead>
                                                                                                                                <thead>
                                                                                                                                        <th>Status</th>
                                                                                                                                        <th>Planta</th>                                                                                                                                                       
                                                                                                                                        <th style="text-align: center">OT</th>                                                                
                                                                                                                                                                                                                                                                                                        
                                                                                                                                </thead>
                                                                                                                                <tbody>
                                                                                                                                        
                                                                                                                                        <tr ng-repeat="row in Budget.budgetPlantsPredictive.slice(((goalcurrentPage-1)*goalitemsPerPage), ((goalcurrentPage)*goalitemsPerPage))">
                                                                                                                                                <td style="text-align: left;width:25px">
                                                                                                                                                        <label class="toggle">
                                                                                                                                                                <input type="checkbox" name="checkbox-toggle" checked="checked" ng-model="row.Active" >
                                                                                                                                                                <i data-swchon-text="ON" data-swchoff-text="OFF"></i>
                                                                                                                                                        </label>  
                                                                                                                                                </td>
                                                                                                                                                <td>
                                                                                                                                                        <label class="label">{{row.Plant.Sheet}} - {{row.Plant.Name}}</label>     
                                                                                                                                                </td>
                                                                                                                                        
                                                                                                                                                <td style="text-align: center;width:70px"> 
                                                                                                                                                        <label class="input">										                        
                                                                                                                                                        <input  type="number" min="0" value="0" step="000" name="txtVlGoal" ng-model="row.vlGoal"/>
                                                                                                                                                        </label>  
                                                                                                                                                </td>
                                                                                                                                        
                                                                                                                                        </tr>
        
                                                                                                                                        
                                                                                                                                </tbody>
                                                                                                                        
                                                                                                                        </table>
                                                                                                                </div>
                                                                                                                <div class="dt-row dt-bottom-row">
                                                                                                                        <div class="row">
                                                                                                                        <section class="col col-6">
                                                                                                                                <div class="dataTables_info">Mostrando de {{goalitemPageStart}} até {{goalitemPageEnd}} de {{goaltotalItems}} registros</div>
                                                                                                                        </section>
                                                                                                                        <section class="col col-6 text-right">
                                                                                                                                <div class="dataTables_paginate paging_bootstrap_full">
                                                                                                                                <ul uib-pagination total-items="goaltotalItems" ng-model="goalcurrentPage" ng-change="pageChanged()" class="pagination-sm" items-per-page="goalitemsPerPage"></ul>
                                                                                                                                </div>
                                                                                                                        </section>
                                                                                                                        </div>
                                                                                                                </div>
                                                                                                         </div>      
                                                                                                </div>
                                                                        </div>        
                                                            </section>
                                                            <div class="row">
                                                            <section class="col col-3">
                                                                    <div class="form-group">                                                                 
                                                                            <label class="toggle">
                                                                                    <input type="checkbox" name="checkbox-toggle" checked="checked" ng-model="Budget.Active">
                                                                                    <i data-swchon-text="ON" data-swchoff-text="OFF"></i>Ativar Budget
                                                                            </label>  
                                                                    </div>          
                                                            </section>   
                                                            </div>                                       

                                                        
                                            </div>
                                            <div ng-class="{'tab-pane fade in active': selTabBudget == 2, 'tab-pane fade': selTabBudget != 2}" id="tBudget2">
                                                    <section>
                                                            
                                                                <div class="dataTables_wrapper form-inline" role="grid">
                                                                                                                                                   
                                                                        <div class="dt-wrapper">
                                                                            <table class="table table-striped table-bordered table-hover">
                                                                               
                                                                                <thead>
                                                                                        <th  style="text-align: center">Status</th>
                                                                                        <th style="text-align: center">Código</th>
                                                                                        <th style="text-align: center">Data de Início</th>
                                                                                        <th style="text-align: center">Data de Fim</th>                                                                                            
                                                                                        <th></th>                                                                                                                                                                     
                                                                                </thead>
                                                                                <tbody>
                                                                                    
                                                                                        <tr ng-repeat="row in budgets.slice(((budgetcurrentPage-1)*budgetitemsPerPage), ((budgetcurrentPage)*budgetitemsPerPage))">
                                                                                                <td style="text-align: left;width:25px">
                                                                                                        <label class="toggle">
                                                                                                                <input type="checkbox" name="checkbox-toggle" checked="checked" ng-model="row.Active" ng-click="updateBudgetStatus(row)">
                                                                                                                <i data-swchon-text="ON" data-swchoff-text="OFF"></i>
                                                                                                        </label>  
                                                                                                </td>
                                                                                                <td align="center" style="width:55px">
                                                                                                        {{row.idBudget}}
                                                                                                </td>
                                                                                                <td align="center">
                                                                                                    
                                                                                                            {{row.dateStart | date:'dd/MM/yyyy'}}     
                                                                                                    
                                                                                                        
                                                                                                </td>
                                                                                                <td align="center"> 
                                                                                                        {{row.dateEnd | date:'dd/MM/yyyy'}}    
                                                                                                </td>
                                                                                                <td style="width:20px">
                                                                                                        <a class="btn btn-warning btn-xs" ng-click="editBudget(row)" style="margin-right: 4px;">
                                                                                                                <span class="glyphicon glyphicon-pencil"></span>
                                                                                                        </a>
                                                                                                </td>
                                                                                                
                                                                                            </tr>
        
                                                                                    
                                                                                </tbody>
                                                                            
                                                                            </table>
                                                                        </div>
                                                                        <div class="dt-row dt-bottom-row">
                                                                            <div class="row">
                                                                                <section class="col col-6">
                                                                                    <div class="dataTables_info">Mostrando de {{budgetitemPageStart}} até {{budgetitemPageEnd}} de {{budgettotalItems}} registros</div>
                                                                                </section>
                                                                                <section class="col col-6 text-right">
                                                                                    <div class="dataTables_paginate paging_bootstrap_full">
                                                                                        <ul uib-pagination total-items="budgettotalItems" ng-model="budgetcurrentPage" ng-change="pageChanged()" class="pagination-sm" items-per-page="budgetitemsPerPage"></ul>
                                                                                    </div>
                                                                                </section>
                                                                            </div>
                                                                        </div>
                                                                </div>            
                                                    </section>   
                                            </div>
                                          
                                    </div>
                                </fieldset>
                                                                
                                <footer>
                            
                                    <button type="submit" class="btn btn-primary">
                                        Salvar
                                    </button>
                                    <button ng-if="Action != 'Insert'" type="button" class="btn btn-primary" ng-click="newBudget()">
                                            Novo
                                    </button>                                     
                                                                    
                                </footer>
                            </form>
    
                        </div>
                        <!-- end widget content -->
                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->		
            </article>
                    
        </div>  
                                       
</section>
 <!-- widget grid -->
 



        
        
        